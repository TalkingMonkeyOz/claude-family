# Claude Family .gitignore

# Generated data files (these are regenerated every session)
postgres/data/*.json
logs/*.txt

# Node modules
node_modules/

# Python cache
__pycache__/
*.py[cod]
*$py.class
*.so

# Environment variables (contains sensitive DB credentials)
.env
# Legacy ai-workspace config.py (contains credentials) - but NOT scripts/config.py (safe loader)
/config.py

# OS files
.DS_Store
Thumbs.db
desktop.ini

# IDE files
.vscode/
.idea/
*.swp
*.swo
*~

# Claude Code local settings (auto-generated permissions)
.claude/settings.local.json
.claude/mcp-*.log
.claude/.current_session_id

# But DO track shared slash commands
!.claude/commands/

# Playwright MCP (local tooling)
.playwright-mcp/

# Downloaded packages
*.tgz

# Temporary files
*.tmp
*.bak
*.log

# PowerShell script (not needed in version control)
create_desktop_shortcut.ps1

# Windows shortcuts
*.lnk

# Any duplicate files from copy errors
*" && *

# Nimbus test artifacts
output/

# MCP config (use .mcp.json.template instead)
.mcp.json
nul

# Obsidian per-user UI state (workspace.json gets rewritten every Obsidian launch)
**/.obsidian/workspace.json
**/.obsidian/workspace-mobile.json

# Downloaded reference repos (keep local, don't track)
knowledge-vault/20-Domains/awesome-copilot-reference/
tools/claude-voice/ClaudeVoice/bin/
tools/claude-voice/ClaudeVoice/obj/
tools/claude-voice/ClaudeVoice/*.csproj.user
docs/external-references/awesome-copilot-reference/
