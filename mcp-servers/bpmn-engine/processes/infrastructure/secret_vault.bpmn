<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions
    xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL"
    xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI"
    xmlns:dc="http://www.omg.org/spec/DD/20100524/DC"
    targetNamespace="http://claude-family/bpmn/secret-vault"
    id="Definitions_SV">

  <!-- ====================================================================== -->
  <!-- PROCESS 1: STORE SECRET                                                -->
  <!-- Claude (or user) stores a credential into Windows Credential Manager   -->
  <!-- ====================================================================== -->

  <bpmn:process id="secret_vault_store" name="Secret Vault: Store Credential" isExecutable="true">

    <!--
      Stores a secret in Windows Credential Manager (WCM) via Python keyring.

      Namespace convention: "claude/{project}/{secret_key}"
        e.g. "claude/nimbus-mui/monash_auth_token"

      Scenarios:
        1. Happy path: keyring available, secret stored successfully
        2. Keyring unavailable (no backend): graceful fallback to session_fact only
        3. Secret already exists: overwrite with new value (rotation)
        4. Invalid input: missing key or value

      Implementation: mcp-servers/project-tools/server_v2.py (set_secret tool)
    -->

    <bpmn:startEvent id="store_start" name="Store Secret Requested">
      <bpmn:outgoing>flow_store_validate</bpmn:outgoing>
    </bpmn:startEvent>

    <!-- PHASE 1: Validate input -->
    <bpmn:scriptTask id="validate_input" name="[CLAUDE] Validate Secret Key and Value" scriptFormat="python">
      <bpmn:incoming>flow_store_validate</bpmn:incoming>
      <bpmn:outgoing>flow_validate_to_gw</bpmn:outgoing>
      <bpmn:script>
# Validate that secret_key and secret_value are non-empty strings
# Validate project_name is provided
# Normalize key: lowercase, no spaces
try:
    if force_invalid_input:
        input_valid = False
        validation_error = "Missing required field: secret_key or secret_value"
    else:
        input_valid = True
        normalized_key = secret_key if secret_key else ""
        service_name = f"claude/{project_name}/{normalized_key}"
except NameError:
    input_valid = True
    normalized_key = secret_key if secret_key else "test_key"
    service_name = f"claude/{project_name}/{normalized_key}"
      </bpmn:script>
    </bpmn:scriptTask>

    <bpmn:exclusiveGateway id="gw_input_valid" name="Input Valid?" default="flow_input_invalid">
      <bpmn:incoming>flow_validate_to_gw</bpmn:incoming>
      <bpmn:outgoing>flow_input_ok</bpmn:outgoing>
      <bpmn:outgoing>flow_input_invalid</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <bpmn:endEvent id="end_invalid_input" name="Error: Invalid Input">
      <bpmn:incoming>flow_input_invalid</bpmn:incoming>
    </bpmn:endEvent>

    <!-- PHASE 2: Check keyring availability -->
    <bpmn:scriptTask id="check_keyring" name="[HOOK] Check Keyring Backend Available" scriptFormat="python">
      <bpmn:incoming>flow_input_ok</bpmn:incoming>
      <bpmn:outgoing>flow_keyring_to_gw</bpmn:outgoing>
      <bpmn:script>
# Try importing keyring and checking for a usable backend
# Windows: WinVaultKeyring (DPAPI-encrypted)
# Linux: SecretService or KWallet
# macOS: Keychain
# No backend: keyring_available = False
try:
    if force_no_keyring:
        keyring_available = False
        keyring_error = "No suitable keyring backend found"
    else:
        keyring_available = True
        backend_name = "WinVaultKeyring"
except NameError:
    keyring_available = True
    backend_name = "WinVaultKeyring"
      </bpmn:script>
    </bpmn:scriptTask>

    <bpmn:exclusiveGateway id="gw_keyring_available" name="Keyring Available?" default="flow_no_keyring">
      <bpmn:incoming>flow_keyring_to_gw</bpmn:incoming>
      <bpmn:outgoing>flow_keyring_ok</bpmn:outgoing>
      <bpmn:outgoing>flow_no_keyring</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <!-- Fallback: store as session fact only (ephemeral) -->
    <bpmn:scriptTask id="fallback_session_fact" name="[DB] Fallback: Store as Session Fact Only" scriptFormat="python">
      <bpmn:incoming>flow_no_keyring</bpmn:incoming>
      <bpmn:outgoing>flow_fallback_to_end</bpmn:outgoing>
      <bpmn:script>
# No keyring backend — fall back to session_fact storage
# Log warning: secret will not persist across sessions
stored_location = "session_fact_only"
persist_across_sessions = False
      </bpmn:script>
    </bpmn:scriptTask>

    <bpmn:endEvent id="end_fallback" name="Stored: Session Fact Only (No Persistence)">
      <bpmn:incoming>flow_fallback_to_end</bpmn:incoming>
    </bpmn:endEvent>

    <!-- PHASE 3: Check if secret already exists (rotation detection) -->
    <bpmn:scriptTask id="check_existing" name="[HOOK] Check If Secret Already Exists in WCM" scriptFormat="python">
      <bpmn:incoming>flow_keyring_ok</bpmn:incoming>
      <bpmn:outgoing>flow_existing_to_gw</bpmn:outgoing>
      <bpmn:script>
# keyring.get_password(service_name, "secret") to check for existing
try:
    if force_existing_secret:
        secret_exists = True
        is_rotation = True
    else:
        secret_exists = False
        is_rotation = False
except NameError:
    secret_exists = False
    is_rotation = False
      </bpmn:script>
    </bpmn:scriptTask>

    <bpmn:exclusiveGateway id="gw_secret_exists" name="Secret Already Exists?" default="flow_not_exists">
      <bpmn:incoming>flow_existing_to_gw</bpmn:incoming>
      <bpmn:outgoing>flow_exists_rotate</bpmn:outgoing>
      <bpmn:outgoing>flow_not_exists</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <bpmn:scriptTask id="log_rotation" name="[LOG] Log: Rotating Existing Secret" scriptFormat="python">
      <bpmn:incoming>flow_exists_rotate</bpmn:incoming>
      <bpmn:outgoing>flow_rotation_to_write</bpmn:outgoing>
      <bpmn:script>
# Log: overwriting existing secret (rotation)
rotation_logged = True
      </bpmn:script>
    </bpmn:scriptTask>

    <!-- PHASE 4: Write to WCM -->
    <bpmn:scriptTask id="write_to_wcm" name="[HOOK] Write Secret to Windows Credential Manager" scriptFormat="python">
      <bpmn:incoming>flow_not_exists</bpmn:incoming>
      <bpmn:incoming>flow_rotation_to_write</bpmn:incoming>
      <bpmn:outgoing>flow_write_to_gw</bpmn:outgoing>
      <bpmn:script>
# keyring.set_password(service_name, "secret", secret_value)
try:
    if force_write_fail:
        write_success = False
        write_error = "WCM write failed: access denied"
    else:
        write_success = True
        stored_location = "windows_credential_manager"
        persist_across_sessions = True
except NameError:
    write_success = True
    stored_location = "windows_credential_manager"
    persist_across_sessions = True
      </bpmn:script>
    </bpmn:scriptTask>

    <bpmn:exclusiveGateway id="gw_write_success" name="Write Succeeded?" default="flow_write_fail">
      <bpmn:incoming>flow_write_to_gw</bpmn:incoming>
      <bpmn:outgoing>flow_write_ok</bpmn:outgoing>
      <bpmn:outgoing>flow_write_fail</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <bpmn:scriptTask id="handle_write_fail" name="[LOG] Log: WCM Write Failed" scriptFormat="python">
      <bpmn:incoming>flow_write_fail</bpmn:incoming>
      <bpmn:outgoing>flow_write_fail_to_end</bpmn:outgoing>
      <bpmn:script>
# Log error and fall back to session fact
stored_location = "session_fact_only"
persist_across_sessions = False
      </bpmn:script>
    </bpmn:scriptTask>

    <bpmn:endEvent id="end_write_fail" name="Stored: Session Fact Only (WCM Write Failed)">
      <bpmn:incoming>flow_write_fail_to_end</bpmn:incoming>
    </bpmn:endEvent>

    <!-- PHASE 5: Also store as session fact for immediate use -->
    <bpmn:scriptTask id="store_session_fact" name="[DB] Also Store as Session Fact for Current Session" scriptFormat="python">
      <bpmn:incoming>flow_write_ok</bpmn:incoming>
      <bpmn:outgoing>flow_session_fact_to_end</bpmn:outgoing>
      <bpmn:script>
# store_session_fact(secret_key, secret_value, "credential", is_sensitive=True)
# This makes it available immediately in the current session
session_fact_stored = True
      </bpmn:script>
    </bpmn:scriptTask>

    <bpmn:endEvent id="end_store_success" name="Stored: WCM + Session Fact">
      <bpmn:incoming>flow_session_fact_to_end</bpmn:incoming>
    </bpmn:endEvent>

    <!-- SEQUENCE FLOWS -->
    <bpmn:sequenceFlow id="flow_store_validate" sourceRef="store_start" targetRef="validate_input"/>
    <bpmn:sequenceFlow id="flow_validate_to_gw" sourceRef="validate_input" targetRef="gw_input_valid"/>
    <bpmn:sequenceFlow id="flow_input_ok" sourceRef="gw_input_valid" targetRef="check_keyring">
      <bpmn:conditionExpression>input_valid == True</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="flow_input_invalid" sourceRef="gw_input_valid" targetRef="end_invalid_input"/>
    <bpmn:sequenceFlow id="flow_keyring_to_gw" sourceRef="check_keyring" targetRef="gw_keyring_available"/>
    <bpmn:sequenceFlow id="flow_keyring_ok" sourceRef="gw_keyring_available" targetRef="check_existing">
      <bpmn:conditionExpression>keyring_available == True</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="flow_no_keyring" sourceRef="gw_keyring_available" targetRef="fallback_session_fact"/>
    <bpmn:sequenceFlow id="flow_fallback_to_end" sourceRef="fallback_session_fact" targetRef="end_fallback"/>
    <bpmn:sequenceFlow id="flow_existing_to_gw" sourceRef="check_existing" targetRef="gw_secret_exists"/>
    <bpmn:sequenceFlow id="flow_exists_rotate" sourceRef="gw_secret_exists" targetRef="log_rotation">
      <bpmn:conditionExpression>secret_exists == True</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="flow_not_exists" sourceRef="gw_secret_exists" targetRef="write_to_wcm"/>
    <bpmn:sequenceFlow id="flow_rotation_to_write" sourceRef="log_rotation" targetRef="write_to_wcm"/>
    <bpmn:sequenceFlow id="flow_write_to_gw" sourceRef="write_to_wcm" targetRef="gw_write_success"/>
    <bpmn:sequenceFlow id="flow_write_ok" sourceRef="gw_write_success" targetRef="store_session_fact">
      <bpmn:conditionExpression>write_success == True</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="flow_write_fail" sourceRef="gw_write_success" targetRef="handle_write_fail"/>
    <bpmn:sequenceFlow id="flow_write_fail_to_end" sourceRef="handle_write_fail" targetRef="end_write_fail"/>
    <bpmn:sequenceFlow id="flow_session_fact_to_end" sourceRef="store_session_fact" targetRef="end_store_success"/>

  </bpmn:process>

  <!-- ====================================================================== -->
  <!-- PROCESS 2: RETRIEVE SECRET                                             -->
  <!-- On-demand retrieval of a single secret from WCM                        -->
  <!-- ====================================================================== -->

  <bpmn:process id="secret_vault_retrieve" name="Secret Vault: Retrieve Credential" isExecutable="true">

    <!--
      Retrieves a secret from Windows Credential Manager.

      Scenarios:
        1. Happy path: keyring available, secret found, returned + cached as session fact
        2. Keyring unavailable: check session facts as fallback
        3. Secret not found in WCM: check session facts as fallback
        4. Not found anywhere: return error with helpful message

      Implementation: mcp-servers/project-tools/server_v2.py (get_secret tool)
    -->

    <bpmn:startEvent id="retrieve_start" name="Retrieve Secret Requested">
      <bpmn:outgoing>flow_retrieve_to_keyring</bpmn:outgoing>
    </bpmn:startEvent>

    <!-- PHASE 1: Check keyring -->
    <bpmn:scriptTask id="r_check_keyring" name="[HOOK] Check Keyring Backend Available" scriptFormat="python">
      <bpmn:incoming>flow_retrieve_to_keyring</bpmn:incoming>
      <bpmn:outgoing>flow_r_keyring_to_gw</bpmn:outgoing>
      <bpmn:script>
try:
    if force_no_keyring:
        keyring_available = False
    else:
        keyring_available = True
        service_name = f"claude/{project_name}/{secret_key}"
except NameError:
    keyring_available = True
    service_name = f"claude/{project_name}/{secret_key}"
      </bpmn:script>
    </bpmn:scriptTask>

    <bpmn:exclusiveGateway id="gw_r_keyring" name="Keyring Available?" default="flow_r_no_keyring">
      <bpmn:incoming>flow_r_keyring_to_gw</bpmn:incoming>
      <bpmn:outgoing>flow_r_keyring_ok</bpmn:outgoing>
      <bpmn:outgoing>flow_r_no_keyring</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <!-- PHASE 2: Read from WCM -->
    <bpmn:scriptTask id="read_from_wcm" name="[HOOK] Read Secret from Windows Credential Manager" scriptFormat="python">
      <bpmn:incoming>flow_r_keyring_ok</bpmn:incoming>
      <bpmn:outgoing>flow_r_read_to_gw</bpmn:outgoing>
      <bpmn:script>
# value = keyring.get_password(service_name, "secret")
try:
    if force_not_found:
        secret_found = False
        secret_value = None
    else:
        secret_found = True
        secret_value = "retrieved_secret_value"
except NameError:
    secret_found = True
    secret_value = "retrieved_secret_value"
      </bpmn:script>
    </bpmn:scriptTask>

    <bpmn:exclusiveGateway id="gw_r_found" name="Secret Found in WCM?" default="flow_r_not_in_wcm">
      <bpmn:incoming>flow_r_read_to_gw</bpmn:incoming>
      <bpmn:outgoing>flow_r_found</bpmn:outgoing>
      <bpmn:outgoing>flow_r_not_in_wcm</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <!-- Found in WCM: cache as session fact -->
    <bpmn:scriptTask id="cache_as_session_fact" name="[DB] Cache Retrieved Secret as Session Fact" scriptFormat="python">
      <bpmn:incoming>flow_r_found</bpmn:incoming>
      <bpmn:outgoing>flow_r_cache_to_end</bpmn:outgoing>
      <bpmn:script>
# store_session_fact(secret_key, secret_value, "credential", is_sensitive=True)
session_fact_cached = True
source = "windows_credential_manager"
      </bpmn:script>
    </bpmn:scriptTask>

    <bpmn:endEvent id="end_retrieve_success" name="Secret Retrieved from WCM">
      <bpmn:incoming>flow_r_cache_to_end</bpmn:incoming>
    </bpmn:endEvent>

    <!-- Not in WCM or no keyring: check session facts -->
    <bpmn:scriptTask id="check_session_facts" name="[DB] Check Session Facts Fallback" scriptFormat="python">
      <bpmn:incoming>flow_r_not_in_wcm</bpmn:incoming>
      <bpmn:incoming>flow_r_no_keyring</bpmn:incoming>
      <bpmn:outgoing>flow_r_session_to_gw</bpmn:outgoing>
      <bpmn:script>
# Check recall_session_fact(secret_key) for the current session
try:
    if force_no_session_fact:
        session_fact_found = False
        secret_value = None
    else:
        session_fact_found = True
        secret_value = "session_fact_value"
        source = "session_fact"
except NameError:
    session_fact_found = False
    secret_value = None
      </bpmn:script>
    </bpmn:scriptTask>

    <bpmn:exclusiveGateway id="gw_r_session" name="Found in Session Facts?" default="flow_r_not_anywhere">
      <bpmn:incoming>flow_r_session_to_gw</bpmn:incoming>
      <bpmn:outgoing>flow_r_in_session</bpmn:outgoing>
      <bpmn:outgoing>flow_r_not_anywhere</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <bpmn:endEvent id="end_retrieve_from_session" name="Secret Retrieved from Session Facts">
      <bpmn:incoming>flow_r_in_session</bpmn:incoming>
    </bpmn:endEvent>

    <!-- Not found anywhere -->
    <bpmn:scriptTask id="handle_not_found" name="[CLAUDE] Prompt User for Credential" scriptFormat="python">
      <bpmn:incoming>flow_r_not_anywhere</bpmn:incoming>
      <bpmn:outgoing>flow_r_not_found_to_end</bpmn:outgoing>
      <bpmn:script>
# Return helpful message: "Secret '{secret_key}' not found. Please provide it
# and I'll store it in the credential vault for next time."
secret_found = False
prompt_user = True
source = "not_found"
      </bpmn:script>
    </bpmn:scriptTask>

    <bpmn:endEvent id="end_not_found" name="Secret Not Found: Prompt User">
      <bpmn:incoming>flow_r_not_found_to_end</bpmn:incoming>
    </bpmn:endEvent>

    <!-- SEQUENCE FLOWS -->
    <bpmn:sequenceFlow id="flow_retrieve_to_keyring" sourceRef="retrieve_start" targetRef="r_check_keyring"/>
    <bpmn:sequenceFlow id="flow_r_keyring_to_gw" sourceRef="r_check_keyring" targetRef="gw_r_keyring"/>
    <bpmn:sequenceFlow id="flow_r_keyring_ok" sourceRef="gw_r_keyring" targetRef="read_from_wcm">
      <bpmn:conditionExpression>keyring_available == True</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="flow_r_no_keyring" sourceRef="gw_r_keyring" targetRef="check_session_facts"/>
    <bpmn:sequenceFlow id="flow_r_read_to_gw" sourceRef="read_from_wcm" targetRef="gw_r_found"/>
    <bpmn:sequenceFlow id="flow_r_found" sourceRef="gw_r_found" targetRef="cache_as_session_fact">
      <bpmn:conditionExpression>secret_found == True</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="flow_r_not_in_wcm" sourceRef="gw_r_found" targetRef="check_session_facts"/>
    <bpmn:sequenceFlow id="flow_r_session_to_gw" sourceRef="check_session_facts" targetRef="gw_r_session"/>
    <bpmn:sequenceFlow id="flow_r_in_session" sourceRef="gw_r_session" targetRef="end_retrieve_from_session">
      <bpmn:conditionExpression>session_fact_found == True</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="flow_r_not_anywhere" sourceRef="gw_r_session" targetRef="handle_not_found"/>
    <bpmn:sequenceFlow id="flow_r_cache_to_end" sourceRef="cache_as_session_fact" targetRef="end_retrieve_success"/>
    <bpmn:sequenceFlow id="flow_r_not_found_to_end" sourceRef="handle_not_found" targetRef="end_not_found"/>

  </bpmn:process>

  <!-- ====================================================================== -->
  <!-- PROCESS 3: SESSION BULK LOAD                                           -->
  <!-- Loads all project secrets from WCM into session facts at session start  -->
  <!-- ====================================================================== -->

  <bpmn:process id="secret_vault_bulk_load" name="Secret Vault: Session Bulk Load" isExecutable="true">

    <!--
      At session start, loads all registered secrets for the current project
      from WCM into session facts. Uses a registry table (claude.secret_registry)
      to know which secrets exist per project.

      Scenarios:
        1. Happy path: registry has entries, all loaded from WCM
        2. No keyring: skip silently (secrets must be entered manually)
        3. Empty registry: no secrets registered for project
        4. Partial load: some secrets missing from WCM (warn but continue)

      Implementation: scripts/session_startup_hook_enhanced.py
    -->

    <bpmn:startEvent id="bulk_start" name="Session Start: Load Project Secrets">
      <bpmn:outgoing>flow_bulk_to_keyring</bpmn:outgoing>
    </bpmn:startEvent>

    <!-- PHASE 1: Check keyring -->
    <bpmn:scriptTask id="b_check_keyring" name="[HOOK] Check Keyring Backend Available" scriptFormat="python">
      <bpmn:incoming>flow_bulk_to_keyring</bpmn:incoming>
      <bpmn:outgoing>flow_b_keyring_to_gw</bpmn:outgoing>
      <bpmn:script>
try:
    if force_no_keyring:
        keyring_available = False
    else:
        keyring_available = True
except NameError:
    keyring_available = True
      </bpmn:script>
    </bpmn:scriptTask>

    <bpmn:exclusiveGateway id="gw_b_keyring" name="Keyring Available?" default="flow_b_no_keyring">
      <bpmn:incoming>flow_b_keyring_to_gw</bpmn:incoming>
      <bpmn:outgoing>flow_b_keyring_ok</bpmn:outgoing>
      <bpmn:outgoing>flow_b_no_keyring</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <bpmn:endEvent id="end_bulk_no_keyring" name="Skip: No Keyring Available">
      <bpmn:incoming>flow_b_no_keyring</bpmn:incoming>
    </bpmn:endEvent>

    <!-- PHASE 2: Query registry for project secrets -->
    <bpmn:scriptTask id="query_registry" name="[DB] Query Secret Registry for Project" scriptFormat="python">
      <bpmn:incoming>flow_b_keyring_ok</bpmn:incoming>
      <bpmn:outgoing>flow_b_registry_to_gw</bpmn:outgoing>
      <bpmn:script>
# SELECT secret_key FROM claude.secret_registry WHERE project_name = ?
try:
    if force_empty_registry:
        registry_entries = []
        registry_count = 0
    else:
        registry_entries = ["monash_auth_token", "t2w_demo_auth", "voyage_api_key"]
        registry_count = len(registry_entries)
except NameError:
    registry_entries = ["monash_auth_token", "t2w_demo_auth", "voyage_api_key"]
    registry_count = len(registry_entries)
      </bpmn:script>
    </bpmn:scriptTask>

    <bpmn:exclusiveGateway id="gw_b_registry" name="Registry Has Entries?" default="flow_b_empty_registry">
      <bpmn:incoming>flow_b_registry_to_gw</bpmn:incoming>
      <bpmn:outgoing>flow_b_has_entries</bpmn:outgoing>
      <bpmn:outgoing>flow_b_empty_registry</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <bpmn:endEvent id="end_bulk_empty" name="Skip: No Secrets Registered for Project">
      <bpmn:incoming>flow_b_empty_registry</bpmn:incoming>
    </bpmn:endEvent>

    <!-- PHASE 3: Load each secret from WCM into session facts -->
    <bpmn:scriptTask id="load_all_secrets" name="[HOOK] Load All Secrets from WCM → Session Facts" scriptFormat="python">
      <bpmn:incoming>flow_b_has_entries</bpmn:incoming>
      <bpmn:outgoing>flow_b_load_to_gw</bpmn:outgoing>
      <bpmn:script>
# For each key in registry_entries:
#   value = keyring.get_password(f"claude/{project_name}/{key}", "secret")
#   if value: store_session_fact(key, value, "credential", is_sensitive=True)
#   else: missing_secrets.append(key)
try:
    if force_partial_load:
        loaded_count = 2
        missing_count = 1
        missing_secrets = ["voyage_api_key"]
        has_missing = True
    else:
        loaded_count = registry_count
        missing_count = 0
        missing_secrets = []
        has_missing = False
except NameError:
    loaded_count = registry_count
    missing_count = 0
    missing_secrets = []
    has_missing = False
      </bpmn:script>
    </bpmn:scriptTask>

    <bpmn:exclusiveGateway id="gw_b_missing" name="Any Secrets Missing?" default="flow_b_all_loaded">
      <bpmn:incoming>flow_b_load_to_gw</bpmn:incoming>
      <bpmn:outgoing>flow_b_has_missing</bpmn:outgoing>
      <bpmn:outgoing>flow_b_all_loaded</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <bpmn:scriptTask id="warn_missing" name="[LOG] Warn: Some Secrets Missing from WCM" scriptFormat="python">
      <bpmn:incoming>flow_b_has_missing</bpmn:incoming>
      <bpmn:outgoing>flow_b_warn_to_end</bpmn:outgoing>
      <bpmn:script>
# Log warning for each missing secret
# Session continues — missing secrets will be prompted on demand
partial_load = True
      </bpmn:script>
    </bpmn:scriptTask>

    <bpmn:endEvent id="end_bulk_partial" name="Loaded: Partial (Some Missing)">
      <bpmn:incoming>flow_b_warn_to_end</bpmn:incoming>
    </bpmn:endEvent>

    <bpmn:endEvent id="end_bulk_success" name="Loaded: All Project Secrets">
      <bpmn:incoming>flow_b_all_loaded</bpmn:incoming>
    </bpmn:endEvent>

    <!-- SEQUENCE FLOWS -->
    <bpmn:sequenceFlow id="flow_bulk_to_keyring" sourceRef="bulk_start" targetRef="b_check_keyring"/>
    <bpmn:sequenceFlow id="flow_b_keyring_to_gw" sourceRef="b_check_keyring" targetRef="gw_b_keyring"/>
    <bpmn:sequenceFlow id="flow_b_keyring_ok" sourceRef="gw_b_keyring" targetRef="query_registry">
      <bpmn:conditionExpression>keyring_available == True</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="flow_b_no_keyring" sourceRef="gw_b_keyring" targetRef="end_bulk_no_keyring"/>
    <bpmn:sequenceFlow id="flow_b_registry_to_gw" sourceRef="query_registry" targetRef="gw_b_registry"/>
    <bpmn:sequenceFlow id="flow_b_has_entries" sourceRef="gw_b_registry" targetRef="load_all_secrets">
      <bpmn:conditionExpression>registry_count > 0</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="flow_b_empty_registry" sourceRef="gw_b_registry" targetRef="end_bulk_empty"/>
    <bpmn:sequenceFlow id="flow_b_load_to_gw" sourceRef="load_all_secrets" targetRef="gw_b_missing"/>
    <bpmn:sequenceFlow id="flow_b_has_missing" sourceRef="gw_b_missing" targetRef="warn_missing">
      <bpmn:conditionExpression>has_missing == True</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="flow_b_all_loaded" sourceRef="gw_b_missing" targetRef="end_bulk_success"/>
    <bpmn:sequenceFlow id="flow_b_warn_to_end" sourceRef="warn_missing" targetRef="end_bulk_partial"/>

  </bpmn:process>

  <!-- ====================================================================== -->
  <!-- DIAGRAM (minimal layout)                                               -->
  <!-- ====================================================================== -->

  <bpmndi:BPMNDiagram id="BPMNDiagram_SV">
    <bpmndi:BPMNPlane id="BPMNPlane_SV" bpmnElement="secret_vault_store">
      <bpmndi:BPMNShape id="s_store_start" bpmnElement="store_start">
        <dc:Bounds x="50" y="240" width="36" height="36"/>
      </bpmndi:BPMNShape>
    </bpmndi:BPMNPlane>
  </bpmndi:BPMNDiagram>

</bpmn:definitions>
