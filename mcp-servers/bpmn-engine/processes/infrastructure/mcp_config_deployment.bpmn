<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions
    xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL"
    xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI"
    xmlns:dc="http://www.omg.org/spec/DD/20100524/DC"
    xmlns:di="http://www.omg.org/spec/DD/20100524/DI"
    targetNamespace="http://claude-family/bpmn/mcp-config-deployment"
    id="Definitions_McpConfigDeployment">

  <bpmn:process id="L2_mcp_config_deployment" name="MCP Config Deployment: DB-Centralized Configuration" isExecutable="true">

    <!--
      Models the DB-centralized MCP configuration system for the Claude Family launcher.

      All-from-DB design: No manual ~/.claude/mcp.json. All MCP servers come from DB
      via a 3-layer merge chain, output to a single {project}/.mcp.json per project.

      3-Layer Merge Chain:
        Layer 1: config_templates (global server configs: mcp-postgres, mcp-project-tools, mcp-sequential-thinking)
        Layer 2: project_type_configs.default_mcp_servers (which globals each project type gets)
        Layer 3: workspaces.startup_config.mcp_configs (project-specific: mui, playwright, bpmn-engine)

      Flow A - Launcher (flow_type="launch"):
        start -> route_gw [launch]
          -> select_project [user]
          -> read_workspace_config [DB]
          -> read_project_type_defaults [DB]
          -> resolve_config_templates [DB]
          -> merge_all_configs [TOOL]
          -> resolve_npx_paths [TOOL]
          -> write_mcp_json [FILE]
          -> deploy_other_configs [TOOL]
          -> launch_claude [TOOL]
          -> load_mcp_configs [CLAUDE]
          -> end_launched

      Flow B - Add/Remove MCP (flow_type="add_remove"):
        start -> route_gw [default/add_remove]
          -> update_db_mcp_configs [DB]
          -> regenerate_project_mcp [TOOL]
          -> record_audit [DB]
          -> end_mcp_changed

      Input: flow_type ("launch" | "add_remove")
    -->

    <!-- ================================================================== -->
    <!-- SHARED ENTRY POINT                                                  -->
    <!-- ================================================================== -->

    <bpmn:startEvent id="start" name="MCP Config Deployment Requested">
      <bpmn:outgoing>flow_start_init</bpmn:outgoing>
    </bpmn:startEvent>

    <!-- Initialize defaults so gateway conditions don't error on missing variables -->
    <bpmn:scriptTask id="init_defaults" name="[INIT] Set Default Values" scriptFormat="python">
      <bpmn:incoming>flow_start_init</bpmn:incoming>
      <bpmn:outgoing>flow_init_route</bpmn:outgoing>
      <bpmn:script>
try:
    _ft = flow_type
except NameError:
    _ft = 'add_remove'
flow_type = _ft
      </bpmn:script>
    </bpmn:scriptTask>

    <!-- Top-level gateway: launcher flow vs add/remove flow -->
    <!-- default=flow_add_remove so that any flow_type != "launch" goes to add/remove -->
    <bpmn:exclusiveGateway id="route_gw" name="Flow Type?" default="flow_add_remove">
      <bpmn:incoming>flow_init_route</bpmn:incoming>
      <bpmn:outgoing>flow_launch</bpmn:outgoing>
      <bpmn:outgoing>flow_add_remove</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <!-- ================================================================== -->
    <!-- FLOW A: LAUNCHER (Launch-Claude-Code-Console.bat)                   -->
    <!-- ================================================================== -->

    <!-- User selects project from DB-driven menu in launcher -->
    <bpmn:userTask id="select_project" name="[USER] Select Project from List">
      <bpmn:incoming>flow_launch</bpmn:incoming>
      <bpmn:outgoing>flow_select_read</bpmn:outgoing>
    </bpmn:userTask>

    <!-- Read workspace config from DB: project_type, startup_config, mcp_configs -->
    <bpmn:scriptTask id="read_workspace_config" name="[DB] Read Workspace Config" scriptFormat="python">
      <bpmn:incoming>flow_select_read</bpmn:incoming>
      <bpmn:outgoing>flow_read_type</bpmn:outgoing>
      <bpmn:script>
# SELECT project_type, startup_config FROM claude.workspaces WHERE name = project_name
# Output: project_type, workspace_mcp_configs (project-specific overrides)
workspace_read_ok = True
try:
    _project_path = project_path
except NameError:
    _project_path = '/projects/default'
project_path = _project_path
try:
    _project_type = project_type
except NameError:
    _project_type = 'application'
project_type = _project_type
try:
    _workspace_mcp_configs = workspace_mcp_configs
except NameError:
    _workspace_mcp_configs = None
workspace_mcp_configs = _workspace_mcp_configs
      </bpmn:script>
    </bpmn:scriptTask>

    <!-- Read default_mcp_servers for this project type (Layer 2) -->
    <bpmn:scriptTask id="read_project_type_defaults" name="[DB] Read Project Type Defaults" scriptFormat="python">
      <bpmn:incoming>flow_read_type</bpmn:incoming>
      <bpmn:outgoing>flow_type_resolve</bpmn:outgoing>
      <bpmn:script>
# SELECT default_mcp_servers FROM claude.project_type_configs WHERE project_type = ?
# Output: default_mcp_servers list (e.g. ['postgres', 'project-tools', 'sequential-thinking'])
try:
    _default_mcp_servers = default_mcp_servers
except NameError:
    _default_mcp_servers = ['postgres', 'project-tools', 'sequential-thinking']
default_mcp_servers = _default_mcp_servers
type_defaults_read = True
      </bpmn:script>
    </bpmn:scriptTask>

    <!-- Resolve each default server name to its config_template content (Layer 1) -->
    <bpmn:scriptTask id="resolve_config_templates" name="[DB] Resolve Config Templates" scriptFormat="python">
      <bpmn:incoming>flow_type_resolve</bpmn:incoming>
      <bpmn:outgoing>flow_resolve_merge</bpmn:outgoing>
      <bpmn:script>
# For each name in default_mcp_servers:
#   SELECT content FROM claude.config_templates WHERE template_name = 'mcp-' + name
# Output: template_configs dict {server_name: config_content}
template_configs = {}
for name in default_mcp_servers:
    template_configs[name] = {'command': 'resolved', 'args': [], 'type': 'stdio'}
templates_resolved = True
template_count = len(template_configs)
      </bpmn:script>
    </bpmn:scriptTask>

    <!-- Merge template defaults + workspace overrides (3-layer merge) -->
    <bpmn:scriptTask id="merge_all_configs" name="[TOOL] 3-Layer Merge" scriptFormat="python">
      <bpmn:incoming>flow_resolve_merge</bpmn:incoming>
      <bpmn:outgoing>flow_merge_resolve_npx</bpmn:outgoing>
      <bpmn:script>
# Start with template_configs (Layer 1+2 merged)
# Overlay workspace_mcp_configs (Layer 3) - project-specific override/add
merged_mcp_configs = dict(template_configs)
if workspace_mcp_configs:
    for name, config in workspace_mcp_configs.items():
        merged_mcp_configs[name] = config
merge_complete = True
server_count = len(merged_mcp_configs)
      </bpmn:script>
    </bpmn:scriptTask>

    <!-- Resolve npx commands to direct node.exe paths for Windows reliability -->
    <bpmn:scriptTask id="resolve_npx_paths" name="[TOOL] Resolve npx to node Paths" scriptFormat="python">
      <bpmn:incoming>flow_merge_resolve_npx</bpmn:incoming>
      <bpmn:outgoing>flow_resolve_write</bpmn:outgoing>
      <bpmn:script>
# Convert: "npx -y @package/server" -> node.exe path for Windows compatibility
# Input: merged_mcp_configs
# Output: resolved_mcp_configs, paths_resolved
resolved_mcp_configs = {}
for name, config in merged_mcp_configs.items():
    resolved = dict(config)
    cmd = config.get('command', '')
    if cmd == 'npx':
        resolved['command'] = 'cmd'
        resolved['args'] = ['/c', 'node'] + config.get('args', [])[2:]
        resolved['_resolved'] = True
    resolved_mcp_configs[name] = resolved
paths_resolved = True
      </bpmn:script>
    </bpmn:scriptTask>

    <!-- Write resolved config to {project}/.mcp.json -->
    <bpmn:scriptTask id="write_mcp_json" name="[FILE] Write .mcp.json" scriptFormat="python">
      <bpmn:incoming>flow_resolve_write</bpmn:incoming>
      <bpmn:outgoing>flow_write_deploy</bpmn:outgoing>
      <bpmn:script>
# Write JSON to {project_path}/.mcp.json
# Format: {"mcpServers": {server_name: {command, args, env}}}
mcp_json_written = True
mcp_json_path = project_path + '/.mcp.json'
      </bpmn:script>
    </bpmn:scriptTask>

    <!-- Deploy other project configs: settings.local.json, CLAUDE.md, rules, skills -->
    <bpmn:scriptTask id="deploy_other_configs" name="[TOOL] Deploy Other Configs" scriptFormat="python">
      <bpmn:incoming>flow_write_deploy</bpmn:incoming>
      <bpmn:outgoing>flow_deploy_launch</bpmn:outgoing>
      <bpmn:script>
# Runs: generate_project_settings.py -> settings.local.json (self-healing from DB)
other_configs_deployed = True
settings_deployed = True
claude_md_deployed = True
      </bpmn:script>
    </bpmn:scriptTask>

    <!-- Launch Claude Code in the project directory -->
    <bpmn:scriptTask id="launch_claude" name="[TOOL] Launch Claude Code" scriptFormat="python">
      <bpmn:incoming>flow_deploy_launch</bpmn:incoming>
      <bpmn:outgoing>flow_launch_load</bpmn:outgoing>
      <bpmn:script>
# Executes: claude --project {project_path}
claude_launched = True
launch_path = project_path
      </bpmn:script>
    </bpmn:scriptTask>

    <!-- Claude Code loads the single .mcp.json (all servers in one file) -->
    <bpmn:scriptTask id="load_mcp_configs" name="[CLAUDE] Load .mcp.json (All Servers)" scriptFormat="python">
      <bpmn:incoming>flow_launch_load</bpmn:incoming>
      <bpmn:outgoing>flow_load_end</bpmn:outgoing>
      <bpmn:script>
# Claude Code reads {project}/.mcp.json (single source, all servers from DB merge)
# Contains: template defaults + workspace-specific servers, all resolved
all_mcps_loaded = True
      </bpmn:script>
    </bpmn:scriptTask>

    <!-- END A: Launcher flow complete, Claude is running -->
    <bpmn:endEvent id="end_launched" name="Claude Running with MCP Config">
      <bpmn:incoming>flow_load_end</bpmn:incoming>
    </bpmn:endEvent>

    <!-- ================================================================== -->
    <!-- FLOW B: ADD/REMOVE MCP SERVER (DB-only, no global tier)             -->
    <!-- ================================================================== -->

    <!-- Update mcp_configs JSONB in the workspaces table -->
    <bpmn:scriptTask id="update_db_mcp_configs" name="[DB] Update workspaces.startup_config.mcp_configs" scriptFormat="python">
      <bpmn:incoming>flow_add_remove</bpmn:incoming>
      <bpmn:outgoing>flow_db_regenerate</bpmn:outgoing>
      <bpmn:script>
# UPDATE claude.workspaces
#   SET startup_config = jsonb_set(startup_config, '{mcp_configs}', new_mcp_configs_json)
# WHERE name = project_name
# Input: project_name, mcp_server_name, mcp_action ('add'|'remove'), mcp_server_config
db_mcp_configs_updated = True
      </bpmn:script>
    </bpmn:scriptTask>

    <!-- Regenerate .mcp.json from DB (full 3-layer merge) -->
    <bpmn:scriptTask id="regenerate_project_mcp" name="[TOOL] Regenerate .mcp.json" scriptFormat="python">
      <bpmn:incoming>flow_db_regenerate</bpmn:incoming>
      <bpmn:outgoing>flow_regenerate_audit</bpmn:outgoing>
      <bpmn:script>
# Runs generate_mcp_config.py for the project
# Re-reads all 3 layers from DB and re-writes .mcp.json
mcp_json_regenerated = True
      </bpmn:script>
    </bpmn:scriptTask>

    <!-- Record the change in audit_log -->
    <bpmn:scriptTask id="record_audit" name="[DB] Record in audit_log" scriptFormat="python">
      <bpmn:incoming>flow_regenerate_audit</bpmn:incoming>
      <bpmn:outgoing>flow_audit_end</bpmn:outgoing>
      <bpmn:script>
# INSERT INTO claude.audit_log (entity_type, entity_id, action, details)
# VALUES ('mcp_config', project_name, mcp_action, jsonb_build_object(...))
audit_recorded = True
      </bpmn:script>
    </bpmn:scriptTask>

    <!-- END B: MCP change committed -->
    <bpmn:endEvent id="end_mcp_changed" name="MCP Config Updated">
      <bpmn:incoming>flow_audit_end</bpmn:incoming>
    </bpmn:endEvent>

    <!-- ================================================================== -->
    <!-- SEQUENCE FLOWS - SHARED ENTRY                                      -->
    <!-- ================================================================== -->

    <bpmn:sequenceFlow id="flow_start_init" sourceRef="start" targetRef="init_defaults"/>
    <bpmn:sequenceFlow id="flow_init_route" sourceRef="init_defaults" targetRef="route_gw"/>

    <bpmn:sequenceFlow id="flow_launch" sourceRef="route_gw" targetRef="select_project">
      <bpmn:conditionExpression>flow_type == "launch"</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <!-- flow_add_remove is the default (no conditionExpression) -->
    <bpmn:sequenceFlow id="flow_add_remove" sourceRef="route_gw" targetRef="update_db_mcp_configs"/>

    <!-- ================================================================== -->
    <!-- SEQUENCE FLOWS - FLOW A (LAUNCHER)                                 -->
    <!-- ================================================================== -->

    <bpmn:sequenceFlow id="flow_select_read" sourceRef="select_project" targetRef="read_workspace_config"/>
    <bpmn:sequenceFlow id="flow_read_type" sourceRef="read_workspace_config" targetRef="read_project_type_defaults"/>
    <bpmn:sequenceFlow id="flow_type_resolve" sourceRef="read_project_type_defaults" targetRef="resolve_config_templates"/>
    <bpmn:sequenceFlow id="flow_resolve_merge" sourceRef="resolve_config_templates" targetRef="merge_all_configs"/>
    <bpmn:sequenceFlow id="flow_merge_resolve_npx" sourceRef="merge_all_configs" targetRef="resolve_npx_paths"/>
    <bpmn:sequenceFlow id="flow_resolve_write" sourceRef="resolve_npx_paths" targetRef="write_mcp_json"/>
    <bpmn:sequenceFlow id="flow_write_deploy" sourceRef="write_mcp_json" targetRef="deploy_other_configs"/>
    <bpmn:sequenceFlow id="flow_deploy_launch" sourceRef="deploy_other_configs" targetRef="launch_claude"/>
    <bpmn:sequenceFlow id="flow_launch_load" sourceRef="launch_claude" targetRef="load_mcp_configs"/>
    <bpmn:sequenceFlow id="flow_load_end" sourceRef="load_mcp_configs" targetRef="end_launched"/>

    <!-- ================================================================== -->
    <!-- SEQUENCE FLOWS - FLOW B (ADD/REMOVE MCP)                           -->
    <!-- ================================================================== -->

    <bpmn:sequenceFlow id="flow_db_regenerate" sourceRef="update_db_mcp_configs" targetRef="regenerate_project_mcp"/>
    <bpmn:sequenceFlow id="flow_regenerate_audit" sourceRef="regenerate_project_mcp" targetRef="record_audit"/>
    <bpmn:sequenceFlow id="flow_audit_end" sourceRef="record_audit" targetRef="end_mcp_changed"/>

  </bpmn:process>

  <!-- ================================================================== -->
  <!-- DIAGRAM LAYOUT                                                      -->
  <!-- ================================================================== -->

  <bpmndi:BPMNDiagram id="BPMNDiagram_1">
    <bpmndi:BPMNPlane id="BPMNPlane_1" bpmnElement="L2_mcp_config_deployment">

      <!-- SHARED ENTRY -->

      <bpmndi:BPMNShape id="s_start" bpmnElement="start">
        <dc:Bounds x="50" y="270" width="36" height="36"/>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="s_init_defaults" bpmnElement="init_defaults">
        <dc:Bounds x="100" y="250" width="120" height="60"/>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="s_route_gw" bpmnElement="route_gw" isMarkerVisible="true">
        <dc:Bounds x="270" y="263" width="50" height="50"/>
      </bpmndi:BPMNShape>

      <!-- FLOW A: LAUNCHER (top lane, y=80..220) -->

      <bpmndi:BPMNShape id="s_select_project" bpmnElement="select_project">
        <dc:Bounds x="250" y="80" width="140" height="80"/>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="s_read_workspace" bpmnElement="read_workspace_config">
        <dc:Bounds x="430" y="80" width="140" height="80"/>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="s_read_type_defaults" bpmnElement="read_project_type_defaults">
        <dc:Bounds x="610" y="80" width="160" height="80"/>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="s_resolve_templates" bpmnElement="resolve_config_templates">
        <dc:Bounds x="810" y="80" width="160" height="80"/>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="s_merge_all" bpmnElement="merge_all_configs">
        <dc:Bounds x="1010" y="80" width="140" height="80"/>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="s_resolve_npx" bpmnElement="resolve_npx_paths">
        <dc:Bounds x="1190" y="80" width="160" height="80"/>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="s_write_mcp" bpmnElement="write_mcp_json">
        <dc:Bounds x="1390" y="80" width="140" height="80"/>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="s_deploy_other" bpmnElement="deploy_other_configs">
        <dc:Bounds x="1570" y="80" width="140" height="80"/>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="s_launch_claude" bpmnElement="launch_claude">
        <dc:Bounds x="1750" y="80" width="140" height="80"/>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="s_load_mcp" bpmnElement="load_mcp_configs">
        <dc:Bounds x="1930" y="80" width="160" height="80"/>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="s_end_launched" bpmnElement="end_launched">
        <dc:Bounds x="2150" y="100" width="36" height="36"/>
      </bpmndi:BPMNShape>

      <!-- FLOW B: ADD/REMOVE MCP (bottom lane, y=420..560) -->

      <bpmndi:BPMNShape id="s_update_db" bpmnElement="update_db_mcp_configs">
        <dc:Bounds x="370" y="440" width="200" height="80"/>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="s_regenerate" bpmnElement="regenerate_project_mcp">
        <dc:Bounds x="630" y="440" width="160" height="80"/>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="s_record_audit" bpmnElement="record_audit">
        <dc:Bounds x="850" y="440" width="160" height="80"/>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="s_end_mcp_changed" bpmnElement="end_mcp_changed">
        <dc:Bounds x="1070" y="460" width="36" height="36"/>
      </bpmndi:BPMNShape>

      <!-- EDGES: SHARED ENTRY -->

      <bpmndi:BPMNEdge id="e_start_init" bpmnElement="flow_start_init">
        <di:waypoint x="86" y="288"/>
        <di:waypoint x="100" y="280"/>
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="e_init_route" bpmnElement="flow_init_route">
        <di:waypoint x="220" y="280"/>
        <di:waypoint x="270" y="288"/>
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="e_launch" bpmnElement="flow_launch">
        <di:waypoint x="295" y="263"/>
        <di:waypoint x="295" y="120"/>
        <di:waypoint x="380" y="120"/>
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="e_add_remove" bpmnElement="flow_add_remove">
        <di:waypoint x="295" y="313"/>
        <di:waypoint x="295" y="480"/>
        <di:waypoint x="370" y="480"/>
      </bpmndi:BPMNEdge>

      <!-- EDGES: FLOW A -->

      <bpmndi:BPMNEdge id="e_select_read" bpmnElement="flow_select_read">
        <di:waypoint x="390" y="120"/>
        <di:waypoint x="430" y="120"/>
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="e_read_type" bpmnElement="flow_read_type">
        <di:waypoint x="570" y="120"/>
        <di:waypoint x="610" y="120"/>
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="e_type_resolve" bpmnElement="flow_type_resolve">
        <di:waypoint x="770" y="120"/>
        <di:waypoint x="810" y="120"/>
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="e_resolve_merge" bpmnElement="flow_resolve_merge">
        <di:waypoint x="970" y="120"/>
        <di:waypoint x="1010" y="120"/>
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="e_merge_resolve_npx" bpmnElement="flow_merge_resolve_npx">
        <di:waypoint x="1150" y="120"/>
        <di:waypoint x="1190" y="120"/>
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="e_resolve_write" bpmnElement="flow_resolve_write">
        <di:waypoint x="1350" y="120"/>
        <di:waypoint x="1390" y="120"/>
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="e_write_deploy" bpmnElement="flow_write_deploy">
        <di:waypoint x="1530" y="120"/>
        <di:waypoint x="1570" y="120"/>
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="e_deploy_launch" bpmnElement="flow_deploy_launch">
        <di:waypoint x="1710" y="120"/>
        <di:waypoint x="1750" y="120"/>
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="e_launch_load" bpmnElement="flow_launch_load">
        <di:waypoint x="1890" y="120"/>
        <di:waypoint x="1930" y="120"/>
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="e_load_end" bpmnElement="flow_load_end">
        <di:waypoint x="2090" y="120"/>
        <di:waypoint x="2150" y="118"/>
      </bpmndi:BPMNEdge>

      <!-- EDGES: FLOW B -->

      <bpmndi:BPMNEdge id="e_db_regenerate" bpmnElement="flow_db_regenerate">
        <di:waypoint x="570" y="480"/>
        <di:waypoint x="630" y="480"/>
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="e_regenerate_audit" bpmnElement="flow_regenerate_audit">
        <di:waypoint x="790" y="480"/>
        <di:waypoint x="850" y="480"/>
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="e_audit_end" bpmnElement="flow_audit_end">
        <di:waypoint x="1010" y="480"/>
        <di:waypoint x="1070" y="478"/>
      </bpmndi:BPMNEdge>

    </bpmndi:BPMNPlane>
  </bpmndi:BPMNDiagram>

</bpmn:definitions>
