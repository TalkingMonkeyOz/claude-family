<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions
    xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL"
    xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI"
    xmlns:dc="http://www.omg.org/spec/DD/20100524/DC"
    xmlns:di="http://www.omg.org/spec/DD/20100524/DI"
    targetNamespace="http://claude-family/bpmn/task-lifecycle"
    id="Definitions_TaskLifecycle">

  <bpmn:process id="task_lifecycle" name="Task Lifecycle" isExecutable="true">

    <!--
      Full task lifecycle including session startup read-back and session boundaries.

      v5 Changes (2026-03-29) — F182: Scope Classification + Completion Reconciliation:
        - Added classify_scope gateway after sync_to_db: parses [S]/[P] prefix,
          writes task_scope column ('session' or 'persistent') to claude.todos
        - Replaced bridge_to_build_task with classify_scope (bridge was unimplemented)
        - Added reconcile_todo step after mark_completed: when a build_task completes,
          finds and closes the matching todo via content fuzzy match
        - Session-end now checks task_scope: session-scoped tasks auto-close,
          persistent tasks go to resume_decision as before
        - Added end_session_closed for session-scoped auto-close path

      v4 Changes (2026-03-15):
        - Added session startup phase: read_tasks_from_db → inject_context
        - Added dedup_check before create_task
        - Removed time-based staleness (holiday-safe) — staleness now user-driven
        - Added read_completed_history for "what did we finish?" context

      Paths:
        1. Startup: SessionStart → ReadFromDB → InjectContext → (existing tasks?) → Resume or Create
        2. Create: DedupCheck → (exists? reuse : create) → Sync → ClassifyScope → Work
        3. Work: InProgress → Work → Complete → ReconcileTodo → FeatureCheck → End(Completed)
        4. Block+Resolve: Work → Block → Resolve → Complete
        5. Midway update: Work → update → MidwayUpdate → Work (loop)
        6. Session end (session-scoped): Work → SessionEnd → ScopeCheck → AutoClose → End(SessionClosed)
        7. Session end (persistent) → resume: Work → SessionEnd → ScopeCheck → Resume → InProgress → Work
        8. Session end (persistent) → abandon: Work → SessionEnd → ScopeCheck → Abandon → Archive → End(Archived)
        9. Discipline block: No tasks → Blocked → End(Blocked)

      Actors:
        [CLAUDE] = userTask (decisions, work)
        [HOOK]   = scriptTask (automated hook operations)
        [DB]     = scriptTask (database operations)
    -->

    <!-- ================================================================== -->
    <!-- START EVENT                                                         -->
    <!-- ================================================================== -->
    <bpmn:startEvent id="start_event" name="Session Start">
      <bpmn:outgoing>flow_start_read_db</bpmn:outgoing>
    </bpmn:startEvent>

    <!-- ================================================================== -->
    <!-- SESSION STARTUP PHASE (NEW v4)                                     -->
    <!-- ================================================================== -->

    <!-- Startup hook queries claude.todos for ALL pending/in_progress tasks (no time limit) -->
    <bpmn:scriptTask id="read_tasks_from_db" name="[HOOK] Read Tasks from DB" scriptFormat="python">
      <bpmn:incoming>flow_start_read_db</bpmn:incoming>
      <bpmn:outgoing>flow_read_completed</bpmn:outgoing>
      <bpmn:script>tasks_read = True
tasks_loaded = tasks_loaded if 'tasks_loaded' in dir() else False</bpmn:script>
      <bpmn:documentation>session_startup_hook_enhanced.py queries ALL pending/in_progress todos
for this project from claude.todos. No time limit — tasks persist until
explicitly completed or archived. Holiday-safe: going on holiday for 2 weeks
does not lose tasks.</bpmn:documentation>
    </bpmn:scriptTask>

    <!-- Also query recently completed tasks from last session -->
    <bpmn:scriptTask id="read_completed_history" name="[HOOK] Read Completed History" scriptFormat="python">
      <bpmn:incoming>flow_read_completed</bpmn:incoming>
      <bpmn:outgoing>flow_inject_context</bpmn:outgoing>
      <bpmn:script>completed_read = True</bpmn:script>
      <bpmn:documentation>Queries completed todos from the last closed session for this project.
Provides "what did we finish?" context without restoring them as active tasks.</bpmn:documentation>
    </bpmn:scriptTask>

    <!-- Inject both into additionalContext so Claude sees existing tasks -->
    <bpmn:scriptTask id="inject_task_context" name="[HOOK] Inject Task Context" scriptFormat="python">
      <bpmn:incoming>flow_inject_context</bpmn:incoming>
      <bpmn:outgoing>flow_context_to_existing_check</bpmn:outgoing>
      <bpmn:script>context_injected = True</bpmn:script>
      <bpmn:documentation>Formats pending tasks and completed history into additionalContext.
Claude sees: "You have N pending tasks: [list]. Last session you completed: [list]."
This prevents duplicate task creation — Claude knows what already exists.</bpmn:documentation>
    </bpmn:scriptTask>

    <!-- Does Claude need to create new tasks or work on existing ones? -->
    <bpmn:exclusiveGateway id="existing_tasks_gw" name="Existing Tasks?" default="flow_no_existing">
      <bpmn:incoming>flow_context_to_existing_check</bpmn:incoming>
      <bpmn:outgoing>flow_has_existing</bpmn:outgoing>
      <bpmn:outgoing>flow_no_existing</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <!-- ================================================================== -->
    <!-- TASK CREATION PHASE (with dedup check)                             -->
    <!-- ================================================================== -->

    <!-- Claude creates tasks via TaskCreate tool -->
    <bpmn:userTask id="create_task" name="[CLAUDE] Create Task">
      <bpmn:incoming>flow_no_existing</bpmn:incoming>
      <bpmn:incoming>flow_more_tasks_loop</bpmn:incoming>
      <bpmn:outgoing>flow_create_sync</bpmn:outgoing>
    </bpmn:userTask>

    <!-- task_sync_hook.py inserts into claude.todos (with dedup check built in) -->
    <bpmn:scriptTask id="sync_to_db" name="[HOOK] Sync to DB (dedup)" scriptFormat="python">
      <bpmn:incoming>flow_create_sync</bpmn:incoming>
      <bpmn:outgoing>flow_sync_bridge</bpmn:outgoing>
      <bpmn:script>synced = True</bpmn:script>
      <bpmn:documentation>task_sync_hook.py checks find_existing_todo() before inserting.
Uses substring match (20+ chars) and fuzzy match (75% threshold).
If existing todo found, reuses it instead of creating duplicate.
Increments restore_count on reuse.</bpmn:documentation>
    </bpmn:scriptTask>

    <!-- Parse [S]/[P] prefix from content, write task_scope to DB -->
    <bpmn:scriptTask id="classify_scope" name="[HOOK] Classify Task Scope ([S]/[P])" scriptFormat="python">
      <bpmn:incoming>flow_sync_classify</bpmn:incoming>
      <bpmn:outgoing>flow_classify_more_tasks</bpmn:outgoing>
      <bpmn:script>
# Parse prefix from content: [S] = session, [P] = persistent
if content.startswith('[S]') or content.startswith('[s]'):
    task_scope = 'session'
elif content.startswith('[P]') or content.startswith('[p]'):
    task_scope = 'persistent'
else:
    task_scope = 'session'  # default: session-scoped (safe — ephemeral)
      </bpmn:script>
      <bpmn:documentation>todo_sync_hook.py parses the [S]/[P] prefix from task content.
[S] = session-scoped (dies when session ends) — reminders, coordination, research steps.
[P] = persistent (survives sessions) — bugs, features, ideas, real work items.
Default is 'session' if no prefix — safe default, ephemeral.
Prefix is stripped from stored content. task_scope column written to claude.todos.</bpmn:documentation>
    </bpmn:scriptTask>

    <!-- Multi-task support: loop back to create_task until all tasks created -->
    <bpmn:exclusiveGateway id="has_more_tasks_gw" name="Has More Tasks?" default="flow_no_more_tasks">
      <bpmn:incoming>flow_bridge_more_tasks</bpmn:incoming>
      <bpmn:outgoing>flow_more_tasks_loop</bpmn:outgoing>
      <bpmn:outgoing>flow_no_more_tasks</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <!-- Discipline gate: must have tasks before tools are allowed -->
    <bpmn:exclusiveGateway id="has_tasks_gw" name="Has Tasks?" default="flow_no_tasks">
      <bpmn:incoming>flow_no_more_tasks</bpmn:incoming>
      <bpmn:incoming>flow_has_existing</bpmn:incoming>
      <bpmn:outgoing>flow_yes_tasks</bpmn:outgoing>
      <bpmn:outgoing>flow_no_tasks</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <!-- ================================================================== -->
    <!-- WORK PHASE                                                          -->
    <!-- ================================================================== -->

    <bpmn:scriptTask id="mark_in_progress" name="[HOOK] Mark In Progress" scriptFormat="python">
      <bpmn:incoming>flow_yes_tasks</bpmn:incoming>
      <bpmn:incoming>flow_do_resume</bpmn:incoming>
      <bpmn:outgoing>flow_progress_work</bpmn:outgoing>
      <bpmn:script>status = "in_progress"</bpmn:script>
    </bpmn:scriptTask>

    <bpmn:userTask id="work_on_task" name="[CLAUDE] Work on Task">
      <bpmn:incoming>flow_progress_work</bpmn:incoming>
      <bpmn:incoming>flow_midway_back</bpmn:incoming>
      <bpmn:outgoing>flow_work_outcome</bpmn:outgoing>
    </bpmn:userTask>

    <bpmn:exclusiveGateway id="outcome_gw" name="Task Action?" default="flow_outcome_complete">
      <bpmn:incoming>flow_work_outcome</bpmn:incoming>
      <bpmn:outgoing>flow_outcome_complete</bpmn:outgoing>
      <bpmn:outgoing>flow_outcome_block</bpmn:outgoing>
      <bpmn:outgoing>flow_outcome_session_end</bpmn:outgoing>
      <bpmn:outgoing>flow_outcome_update</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <!-- ================================================================== -->
    <!-- PATH: MIDWAY STATUS UPDATE                                          -->
    <!-- ================================================================== -->

    <bpmn:scriptTask id="midway_status_update" name="[CLAUDE] Update Task Status" scriptFormat="python">
      <bpmn:incoming>flow_outcome_update</bpmn:incoming>
      <bpmn:outgoing>flow_midway_back</bpmn:outgoing>
      <bpmn:script>midway_updated = True</bpmn:script>
    </bpmn:scriptTask>

    <!-- ================================================================== -->
    <!-- PATH: COMPLETE                                                      -->
    <!-- ================================================================== -->

    <bpmn:scriptTask id="mark_completed" name="[HOOK] Mark Completed (TaskCompleted)" scriptFormat="python">
      <bpmn:incoming>flow_outcome_complete</bpmn:incoming>
      <bpmn:incoming>flow_resolve_complete</bpmn:incoming>
      <bpmn:outgoing>flow_completed_reconcile</bpmn:outgoing>
      <bpmn:script>status = "completed"</bpmn:script>
      <bpmn:documentation>Uses TaskCompleted hook (reliable — fires on every completion).
Claude Code deletes the task JSON file from disk on completion.
task_completed_hook.py preserves the completed status in claude.todos DB.</bpmn:documentation>
    </bpmn:scriptTask>

    <!-- v5: Reconcile — if a build_task was completed, close matching todo -->
    <bpmn:scriptTask id="reconcile_todo" name="[HOOK] Reconcile Todo with Build Task" scriptFormat="python">
      <bpmn:incoming>flow_completed_reconcile</bpmn:incoming>
      <bpmn:outgoing>flow_reconcile_feature_check</bpmn:outgoing>
      <bpmn:script>reconciled = True</bpmn:script>
      <bpmn:documentation>When work_status(action="complete",BT123) finishes a build_task, the task_completed_hook
finds the matching todo in claude.todos by content fuzzy match and marks it
completed too. This prevents "Add version history" staying open after F180/BT529
was completed. Uses same similarity_ratio function (75% threshold) as dedup.</bpmn:documentation>
    </bpmn:scriptTask>

    <bpmn:scriptTask id="check_feature_completion" name="[DB] Check Feature Completion" scriptFormat="python">
      <bpmn:incoming>flow_reconcile_feature_check</bpmn:incoming>
      <bpmn:outgoing>flow_completed_end</bpmn:outgoing>
      <bpmn:script>feature_completion_checked = True</bpmn:script>
    </bpmn:scriptTask>

    <bpmn:endEvent id="end_completed" name="Task Completed">
      <bpmn:incoming>flow_completed_end</bpmn:incoming>
    </bpmn:endEvent>

    <!-- ================================================================== -->
    <!-- PATH: BLOCKED → RESOLVE → COMPLETE                                  -->
    <!-- ================================================================== -->

    <bpmn:userTask id="resolve_blocker" name="[CLAUDE] Resolve Blocker">
      <bpmn:incoming>flow_outcome_block</bpmn:incoming>
      <bpmn:outgoing>flow_resolve_complete</bpmn:outgoing>
    </bpmn:userTask>

    <!-- ================================================================== -->
    <!-- PATH: SESSION END → DEMOTE → RESUME/ARCHIVE                         -->
    <!-- ================================================================== -->

    <!-- v5: Check task_scope before deciding what to do at session end -->
    <bpmn:exclusiveGateway id="scope_check_gw" name="Task Scope?" default="flow_scope_session">
      <bpmn:incoming>flow_outcome_session_end</bpmn:incoming>
      <bpmn:outgoing>flow_scope_session</bpmn:outgoing>
      <bpmn:outgoing>flow_scope_persistent</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <!-- Session-scoped tasks: auto-close, no resume decision needed -->
    <bpmn:scriptTask id="auto_close_session_task" name="[HOOK] Auto-Close Session Task" scriptFormat="python">
      <bpmn:incoming>flow_scope_session</bpmn:incoming>
      <bpmn:outgoing>flow_session_closed_end</bpmn:outgoing>
      <bpmn:script>status = "cancelled"
task_scope = "session"</bpmn:script>
      <bpmn:documentation>session_end_hook.py auto-closes all todos where task_scope='session'.
These are ephemeral tasks (reminders, research steps, coordination) that
don't need to survive the session. Cancelled, not archived — they were
never real work items.</bpmn:documentation>
    </bpmn:scriptTask>

    <bpmn:endEvent id="end_session_closed" name="Session Task Auto-Closed">
      <bpmn:incoming>flow_session_closed_end</bpmn:incoming>
    </bpmn:endEvent>

    <!-- Persistent tasks: demote and ask about resumption (unchanged from v4) -->
    <bpmn:scriptTask id="demote_to_pending" name="[HOOK] Demote to Pending" scriptFormat="python">
      <bpmn:incoming>flow_scope_persistent</bpmn:incoming>
      <bpmn:outgoing>flow_demote_resume</bpmn:outgoing>
      <bpmn:script>status = "pending"</bpmn:script>
      <bpmn:documentation>Persistent tasks survive sessions. No time-based auto-archive.
Tasks persist indefinitely until user explicitly completes or archives.
Holiday-safe.</bpmn:documentation>
    </bpmn:scriptTask>

    <!-- Next session: Claude decides whether to resume or abandon -->
    <bpmn:userTask id="resume_decision" name="[CLAUDE] Resume or Abandon?">
      <bpmn:incoming>flow_demote_resume</bpmn:incoming>
      <bpmn:outgoing>flow_resume_choice</bpmn:outgoing>
    </bpmn:userTask>

    <bpmn:exclusiveGateway id="resume_gw" name="Resume?" default="flow_do_resume">
      <bpmn:incoming>flow_resume_choice</bpmn:incoming>
      <bpmn:outgoing>flow_do_resume</bpmn:outgoing>
      <bpmn:outgoing>flow_do_abandon</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <!-- Archive (reached from abandonment only — no auto-staleness) -->
    <bpmn:scriptTask id="archive_task" name="[HOOK] Archive Task" scriptFormat="python">
      <bpmn:incoming>flow_do_abandon</bpmn:incoming>
      <bpmn:outgoing>flow_archive_end</bpmn:outgoing>
      <bpmn:script>status = "archived"</bpmn:script>
    </bpmn:scriptTask>

    <bpmn:endEvent id="end_archived" name="Task Archived">
      <bpmn:incoming>flow_archive_end</bpmn:incoming>
    </bpmn:endEvent>

    <!-- ================================================================== -->
    <!-- PATH: DISCIPLINE GATE BLOCKED                                       -->
    <!-- ================================================================== -->

    <bpmn:scriptTask id="mark_gate_blocked" name="[HOOK] Discipline Gate (Write/Edit/Bash/Task blocked)" scriptFormat="python">
      <bpmn:incoming>flow_no_tasks</bpmn:incoming>
      <bpmn:outgoing>flow_blocked_end</bpmn:outgoing>
      <bpmn:script>gate_blocked = True</bpmn:script>
      <bpmn:documentation>task_discipline_hook.py blocks GATED_TOOLS = {Write, Edit, Bash, Task}
when no tasks have been created in the current session.</bpmn:documentation>
    </bpmn:scriptTask>

    <bpmn:endEvent id="end_blocked" name="Blocked by Discipline Gate">
      <bpmn:incoming>flow_blocked_end</bpmn:incoming>
    </bpmn:endEvent>

    <!-- ================================================================== -->
    <!-- SEQUENCE FLOWS                                                      -->
    <!-- ================================================================== -->

    <!-- Startup phase (NEW v4) -->
    <bpmn:sequenceFlow id="flow_start_read_db" sourceRef="start_event" targetRef="read_tasks_from_db"/>
    <bpmn:sequenceFlow id="flow_read_completed" sourceRef="read_tasks_from_db" targetRef="read_completed_history"/>
    <bpmn:sequenceFlow id="flow_inject_context" sourceRef="read_completed_history" targetRef="inject_task_context"/>
    <bpmn:sequenceFlow id="flow_context_to_existing_check" sourceRef="inject_task_context" targetRef="existing_tasks_gw"/>

    <!-- Existing tasks path -->
    <bpmn:sequenceFlow id="flow_has_existing" sourceRef="existing_tasks_gw" targetRef="has_tasks_gw">
      <bpmn:conditionExpression>tasks_loaded == True</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="flow_no_existing" sourceRef="existing_tasks_gw" targetRef="create_task"/>

    <!-- Creation phase (v5: sync → classify_scope → more_tasks) -->
    <bpmn:sequenceFlow id="flow_create_sync" sourceRef="create_task" targetRef="sync_to_db"/>
    <bpmn:sequenceFlow id="flow_sync_classify" sourceRef="sync_to_db" targetRef="classify_scope"/>
    <bpmn:sequenceFlow id="flow_classify_more_tasks" sourceRef="classify_scope" targetRef="has_more_tasks_gw"/>

    <!-- Multi-task loop -->
    <bpmn:sequenceFlow id="flow_more_tasks_loop" sourceRef="has_more_tasks_gw" targetRef="create_task">
      <bpmn:conditionExpression>has_more_tasks == True</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="flow_no_more_tasks" sourceRef="has_more_tasks_gw" targetRef="has_tasks_gw"/>

    <!-- Discipline gate -->
    <bpmn:sequenceFlow id="flow_yes_tasks" sourceRef="has_tasks_gw" targetRef="mark_in_progress">
      <bpmn:conditionExpression>has_tasks == True</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="flow_no_tasks" sourceRef="has_tasks_gw" targetRef="mark_gate_blocked"/>

    <!-- Work phase -->
    <bpmn:sequenceFlow id="flow_progress_work" sourceRef="mark_in_progress" targetRef="work_on_task"/>
    <bpmn:sequenceFlow id="flow_work_outcome" sourceRef="work_on_task" targetRef="outcome_gw"/>

    <!-- Outcome: complete (default) — v5: includes reconciliation step -->
    <bpmn:sequenceFlow id="flow_outcome_complete" sourceRef="outcome_gw" targetRef="mark_completed"/>
    <bpmn:sequenceFlow id="flow_completed_reconcile" sourceRef="mark_completed" targetRef="reconcile_todo"/>
    <bpmn:sequenceFlow id="flow_reconcile_feature_check" sourceRef="reconcile_todo" targetRef="check_feature_completion"/>
    <bpmn:sequenceFlow id="flow_completed_end" sourceRef="check_feature_completion" targetRef="end_completed"/>

    <!-- Outcome: blocked -->
    <bpmn:sequenceFlow id="flow_outcome_block" sourceRef="outcome_gw" targetRef="resolve_blocker">
      <bpmn:conditionExpression>action == "block"</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="flow_resolve_complete" sourceRef="resolve_blocker" targetRef="mark_completed"/>

    <!-- Outcome: midway update -->
    <bpmn:sequenceFlow id="flow_outcome_update" sourceRef="outcome_gw" targetRef="midway_status_update">
      <bpmn:conditionExpression>action == "update"</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="flow_midway_back" sourceRef="midway_status_update" targetRef="work_on_task"/>

    <!-- Outcome: session end — v5: check scope first -->
    <bpmn:sequenceFlow id="flow_outcome_session_end" sourceRef="outcome_gw" targetRef="scope_check_gw">
      <bpmn:conditionExpression>action == "session_end"</bpmn:conditionExpression>
    </bpmn:sequenceFlow>

    <!-- v5: Scope check routes session tasks to auto-close, persistent to resume -->
    <bpmn:sequenceFlow id="flow_scope_session" sourceRef="scope_check_gw" targetRef="auto_close_session_task"/>
    <bpmn:sequenceFlow id="flow_scope_persistent" sourceRef="scope_check_gw" targetRef="demote_to_pending">
      <bpmn:conditionExpression>task_scope == "persistent"</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="flow_session_closed_end" sourceRef="auto_close_session_task" targetRef="end_session_closed"/>

    <!-- Session boundary: persistent tasks demote → resume decision -->
    <bpmn:sequenceFlow id="flow_demote_resume" sourceRef="demote_to_pending" targetRef="resume_decision"/>

    <!-- Resume decision -->
    <bpmn:sequenceFlow id="flow_resume_choice" sourceRef="resume_decision" targetRef="resume_gw"/>
    <bpmn:sequenceFlow id="flow_do_resume" sourceRef="resume_gw" targetRef="mark_in_progress"/>
    <bpmn:sequenceFlow id="flow_do_abandon" sourceRef="resume_gw" targetRef="archive_task">
      <bpmn:conditionExpression>decision == "abandon"</bpmn:conditionExpression>
    </bpmn:sequenceFlow>

    <!-- Archive end -->
    <bpmn:sequenceFlow id="flow_archive_end" sourceRef="archive_task" targetRef="end_archived"/>

    <!-- Gate blocked end -->
    <bpmn:sequenceFlow id="flow_blocked_end" sourceRef="mark_gate_blocked" targetRef="end_blocked"/>

  </bpmn:process>

  <!-- Diagram layout -->
  <bpmndi:BPMNDiagram id="BPMNDiagram_1">
    <bpmndi:BPMNPlane id="BPMNPlane_1" bpmnElement="task_lifecycle">
      <!-- Minimal layout — visual editors will auto-arrange -->
      <bpmndi:BPMNShape id="s_start" bpmnElement="start_event">
        <dc:Bounds x="50" y="200" width="36" height="36"/>
      </bpmndi:BPMNShape>
    </bpmndi:BPMNPlane>
  </bpmndi:BPMNDiagram>

</bpmn:definitions>
