<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions
    xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL"
    xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI"
    xmlns:dc="http://www.omg.org/spec/DD/20100524/DC"
    xmlns:di="http://www.omg.org/spec/DD/20100524/DI"
    targetNamespace="http://claude-family/bpmn/project-lifecycle"
    id="Definitions_PL">

  <!-- ====================================================================== -->
  <!-- PROCESS 1: Project Lifecycle (Init to Maturity)                        -->
  <!-- The overall project lifecycle from creation through work to retirement -->
  <!-- ====================================================================== -->
  <bpmn:process id="project_lifecycle" name="Project Lifecycle: Init to Maturity" isExecutable="true">

    <!--
      Full project lifecycle from creation through phases to retirement.

      Paths:
        1. New project: Init -> Register -> Generate Config -> Governance Docs -> Setup Phase
        2. Existing project: Load -> Compliance Check -> Fix or Continue
        3. Phase advancement: Assess readiness -> Advance via phase_advancement subprocess
        4. Config change: Update DB -> Regenerate Files -> Verify

      Actors:
        [CLAUDE]  = userTask (decisions, authoring)
        [SKILL]   = scriptTask (skill invocation: /project-init, /check-compliance)
        [DB]      = scriptTask (database operations)
        [SCRIPT]  = scriptTask (generate_project_settings.py, deploy scripts)
        [MCP]     = scriptTask (project-tools MCP calls)

      Implementation:
        - /project-init skill -> SQL inserts + generate_project_settings.py
        - Config Management SOP (knowledge-vault/40-Procedures/)
        - generate_project_settings.py (3-layer merge)
        - v_project_governance view for compliance checks
    -->

    <!-- ================================================================== -->
    <!-- START EVENT                                                         -->
    <!-- ================================================================== -->
    <bpmn:startEvent id="start" name="Project Need Identified">
      <bpmn:outgoing>flow_start_to_classify</bpmn:outgoing>
    </bpmn:startEvent>

    <!-- ================================================================== -->
    <!-- CLASSIFICATION: New or Existing?                                    -->
    <!-- ================================================================== -->
    <bpmn:userTask id="classify_project" name="[CLAUDE] New or Existing Project?">
      <bpmn:incoming>flow_start_to_classify</bpmn:incoming>
      <bpmn:outgoing>flow_classify_to_gw</bpmn:outgoing>
    </bpmn:userTask>

    <bpmn:exclusiveGateway id="new_or_existing_gw" name="New or Existing?" default="flow_existing">
      <bpmn:incoming>flow_classify_to_gw</bpmn:incoming>
      <bpmn:outgoing>flow_new_project</bpmn:outgoing>
      <bpmn:outgoing>flow_existing</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <!-- ================================================================== -->
    <!-- PATH A: NEW PROJECT CREATION                                       -->
    <!-- ================================================================== -->

    <bpmn:userTask id="define_project" name="[CLAUDE] Define Project (name, type, description)">
      <bpmn:incoming>flow_new_project</bpmn:incoming>
      <bpmn:outgoing>flow_define_to_register</bpmn:outgoing>
    </bpmn:userTask>

    <bpmn:scriptTask id="register_in_db" name="[DB] Register Project (projects, workspaces, identities)" scriptFormat="python">
      <bpmn:incoming>flow_define_to_register</bpmn:incoming>
      <bpmn:outgoing>flow_register_to_generate</bpmn:outgoing>
      <bpmn:script>
# INSERT claude.projects (project_id, project_name, phase='idea', status='active')
# INSERT claude.workspaces (project_type from: infrastructure, csharp-desktop, csharp-winforms, web-app, tauri-react)
# INSERT claude.identities (linked to project)
# workspace.startup_config = {} (JSONB for project-specific overrides)
# New projects start in 'idea' phase
try:
    if registered is None:
        registered = True
except NameError:
    registered = True
      </bpmn:script>
    </bpmn:scriptTask>

    <bpmn:scriptTask id="generate_settings" name="[SCRIPT] Generate Settings (3-layer merge)" scriptFormat="python">
      <bpmn:incoming>flow_register_to_generate</bpmn:incoming>
      <bpmn:outgoing>flow_generate_to_docs</bpmn:outgoing>
      <bpmn:script>
# generate_project_settings.py performs 3-layer merge:
#   Layer 1: config_templates (template_name='hooks-base') - base hooks
#   Layer 2: project_type_configs (by project_type) - MCPs, skills, instructions
#   Layer 3: workspaces.startup_config (project-specific overrides, last wins)
# Preserves existing permissions from current settings file
# Output: .claude/settings.local.json
try:
    if settings_generated is None:
        settings_generated = True
except NameError:
    settings_generated = True
      </bpmn:script>
    </bpmn:scriptTask>

    <bpmn:userTask id="create_governance_docs" name="[CLAUDE] Create Governance Docs (CLAUDE.md, PROBLEM_STATEMENT.md, ARCHITECTURE.md)">
      <bpmn:incoming>flow_generate_to_docs</bpmn:incoming>
      <bpmn:outgoing>flow_docs_to_mcp</bpmn:outgoing>
    </bpmn:userTask>

    <bpmn:scriptTask id="register_mcp" name="[DB] Register MCP Config (.mcp.json + claude.mcp_configs)" scriptFormat="python">
      <bpmn:incoming>flow_docs_to_mcp</bpmn:incoming>
      <bpmn:outgoing>flow_mcp_to_compliance</bpmn:outgoing>
      <bpmn:script>
# Create .mcp.json in project root
# INSERT into claude.mcp_configs for each MCP server
# Update workspaces.startup_config with mcpServers list
try:
    if mcp_registered is None:
        mcp_registered = True
except NameError:
    mcp_registered = True
      </bpmn:script>
    </bpmn:scriptTask>

    <!-- ================================================================== -->
    <!-- PATH B: EXISTING PROJECT                                           -->
    <!-- ================================================================== -->

    <bpmn:scriptTask id="load_project" name="[MCP] Load Project Context (start_session)" scriptFormat="python">
      <bpmn:incoming>flow_existing</bpmn:incoming>
      <bpmn:outgoing>flow_load_to_compliance</bpmn:outgoing>
      <bpmn:script>
# start_session(project, resume=True/False)
# Returns: project info, session state, todos, features, messages
try:
    if project_loaded is None:
        project_loaded = True
except NameError:
    project_loaded = True
      </bpmn:script>
    </bpmn:scriptTask>

    <!-- ================================================================== -->
    <!-- COMPLIANCE CHECK (both paths converge)                             -->
    <!-- ================================================================== -->

    <bpmn:exclusiveGateway id="compliance_merge" name="Merge">
      <bpmn:incoming>flow_mcp_to_compliance</bpmn:incoming>
      <bpmn:incoming>flow_load_to_compliance</bpmn:incoming>
      <bpmn:outgoing>flow_merge_to_check</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <bpmn:scriptTask id="check_compliance" name="[DB] Check Compliance (v_project_governance)" scriptFormat="python">
      <bpmn:incoming>flow_merge_to_check</bpmn:incoming>
      <bpmn:outgoing>flow_check_to_gw</bpmn:outgoing>
      <bpmn:script>
# Query v_project_governance view:
#   - has_claude_md, has_problem_statement, has_architecture
#   - has_settings, has_mcp_config
#   - workspace registered, identity registered
# compliance_ok = all checks pass
try:
    if compliance_ok is None:
        compliance_ok = True
except NameError:
    compliance_ok = True
      </bpmn:script>
    </bpmn:scriptTask>

    <bpmn:exclusiveGateway id="compliance_gw" name="Compliant?" default="flow_compliant">
      <bpmn:incoming>flow_check_to_gw</bpmn:incoming>
      <bpmn:outgoing>flow_compliant</bpmn:outgoing>
      <bpmn:outgoing>flow_not_compliant</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <bpmn:userTask id="fix_compliance" name="[CLAUDE] Fix Compliance Gaps">
      <bpmn:incoming>flow_not_compliant</bpmn:incoming>
      <bpmn:outgoing>flow_fix_to_recheck</bpmn:outgoing>
    </bpmn:userTask>

    <!-- ================================================================== -->
    <!-- WORK PHASE                                                         -->
    <!-- ================================================================== -->

    <bpmn:exclusiveGateway id="work_merge" name="Work Merge">
      <bpmn:incoming>flow_compliant</bpmn:incoming>
      <bpmn:incoming>flow_fix_to_recheck</bpmn:incoming>
      <bpmn:outgoing>flow_to_work</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <bpmn:userTask id="do_work" name="[CLAUDE] Do Work (feature development)">
      <bpmn:incoming>flow_to_work</bpmn:incoming>
      <bpmn:incoming>flow_config_to_work</bpmn:incoming>
      <bpmn:incoming>flow_advance_to_work</bpmn:incoming>
      <bpmn:outgoing>flow_work_to_action</bpmn:outgoing>
    </bpmn:userTask>

    <bpmn:exclusiveGateway id="action_gw" name="Next Action?" default="flow_continue_work">
      <bpmn:incoming>flow_work_to_action</bpmn:incoming>
      <bpmn:outgoing>flow_continue_work</bpmn:outgoing>
      <bpmn:outgoing>flow_config_change</bpmn:outgoing>
      <bpmn:outgoing>flow_phase_advance</bpmn:outgoing>
      <bpmn:outgoing>flow_retire</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <!-- ================================================================== -->
    <!-- CONFIG CHANGE SUBPROCESS                                           -->
    <!-- ================================================================== -->

    <bpmn:scriptTask id="update_config_db" name="[DB] Update Config in Database" scriptFormat="python">
      <bpmn:incoming>flow_config_change</bpmn:incoming>
      <bpmn:outgoing>flow_db_to_regen</bpmn:outgoing>
      <bpmn:script>
# Depending on scope:
#   All projects: UPDATE config_templates (template_name='hooks-base')
#   All of type:  UPDATE project_type_configs
#   Single:       UPDATE workspaces.startup_config (JSONB merge)
# Or use MCP tools: update_claude_md(), regenerate_settings()
try:
    if config_updated is None:
        config_updated = True
except NameError:
    config_updated = True
      </bpmn:script>
    </bpmn:scriptTask>

    <bpmn:scriptTask id="regenerate_files" name="[SCRIPT] Regenerate Files (settings, CLAUDE.md)" scriptFormat="python">
      <bpmn:incoming>flow_db_to_regen</bpmn:incoming>
      <bpmn:outgoing>flow_regen_to_verify</bpmn:outgoing>
      <bpmn:script>
# regenerate_settings(project) -> .claude/settings.local.json
# deploy_claude_md(project) -> CLAUDE.md from profiles.config->'behavior'
# deploy_project(project, components) -> rules, skills, instructions
# Logged to config_deployment_log
try:
    if files_regenerated is None:
        files_regenerated = True
except NameError:
    files_regenerated = True
      </bpmn:script>
    </bpmn:scriptTask>

    <bpmn:scriptTask id="verify_config" name="[SCRIPT] Verify Config (diff check)" scriptFormat="python">
      <bpmn:incoming>flow_regen_to_verify</bpmn:incoming>
      <bpmn:outgoing>flow_config_to_work</bpmn:outgoing>
      <bpmn:script>
# Compare generated files with expected content
# Check settings.local.json has correct hooks, MCPs, permissions
# Verify CLAUDE.md sections match DB
config_verified = True
      </bpmn:script>
    </bpmn:scriptTask>

    <!-- ================================================================== -->
    <!-- PHASE ADVANCEMENT (calls phase_advancement process)                -->
    <!-- ================================================================== -->

    <bpmn:callActivity id="assess_and_advance_phase" name="[SUBPROCESS] Phase Advancement" calledElement="phase_advancement">
      <bpmn:incoming>flow_phase_advance</bpmn:incoming>
      <bpmn:outgoing>flow_advance_to_work</bpmn:outgoing>
    </bpmn:callActivity>

    <!-- ================================================================== -->
    <!-- RETIREMENT                                                         -->
    <!-- ================================================================== -->

    <bpmn:scriptTask id="archive_project" name="[DB] Archive Project (status='archived')" scriptFormat="python">
      <bpmn:incoming>flow_retire</bpmn:incoming>
      <bpmn:outgoing>flow_archive_to_end</bpmn:outgoing>
      <bpmn:script>
# UPDATE claude.projects SET status = 'archived', phase = 'archived'
# Close all open features, build_tasks
# Archive session data
project_archived = True
      </bpmn:script>
    </bpmn:scriptTask>

    <!-- ================================================================== -->
    <!-- END EVENTS                                                         -->
    <!-- ================================================================== -->

    <bpmn:endEvent id="end_active" name="Project Active">
      <bpmn:incoming>flow_continue_work</bpmn:incoming>
    </bpmn:endEvent>

    <bpmn:endEvent id="end_archived" name="Project Archived">
      <bpmn:incoming>flow_archive_to_end</bpmn:incoming>
    </bpmn:endEvent>

    <!-- ================================================================== -->
    <!-- SEQUENCE FLOWS                                                     -->
    <!-- ================================================================== -->

    <bpmn:sequenceFlow id="flow_start_to_classify" sourceRef="start" targetRef="classify_project"/>
    <bpmn:sequenceFlow id="flow_classify_to_gw" sourceRef="classify_project" targetRef="new_or_existing_gw"/>

    <!-- New project path -->
    <bpmn:sequenceFlow id="flow_new_project" sourceRef="new_or_existing_gw" targetRef="define_project">
      <bpmn:conditionExpression>project_type == "new"</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="flow_define_to_register" sourceRef="define_project" targetRef="register_in_db"/>
    <bpmn:sequenceFlow id="flow_register_to_generate" sourceRef="register_in_db" targetRef="generate_settings"/>
    <bpmn:sequenceFlow id="flow_generate_to_docs" sourceRef="generate_settings" targetRef="create_governance_docs"/>
    <bpmn:sequenceFlow id="flow_docs_to_mcp" sourceRef="create_governance_docs" targetRef="register_mcp"/>
    <bpmn:sequenceFlow id="flow_mcp_to_compliance" sourceRef="register_mcp" targetRef="compliance_merge"/>

    <!-- Existing project path -->
    <bpmn:sequenceFlow id="flow_existing" sourceRef="new_or_existing_gw" targetRef="load_project"/>
    <bpmn:sequenceFlow id="flow_load_to_compliance" sourceRef="load_project" targetRef="compliance_merge"/>

    <!-- Compliance check -->
    <bpmn:sequenceFlow id="flow_merge_to_check" sourceRef="compliance_merge" targetRef="check_compliance"/>
    <bpmn:sequenceFlow id="flow_check_to_gw" sourceRef="check_compliance" targetRef="compliance_gw"/>
    <bpmn:sequenceFlow id="flow_compliant" sourceRef="compliance_gw" targetRef="work_merge"/>
    <bpmn:sequenceFlow id="flow_not_compliant" sourceRef="compliance_gw" targetRef="fix_compliance">
      <bpmn:conditionExpression>compliance_ok == False</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="flow_fix_to_recheck" sourceRef="fix_compliance" targetRef="work_merge"/>

    <!-- Work phase -->
    <bpmn:sequenceFlow id="flow_to_work" sourceRef="work_merge" targetRef="do_work"/>
    <bpmn:sequenceFlow id="flow_work_to_action" sourceRef="do_work" targetRef="action_gw"/>
    <bpmn:sequenceFlow id="flow_continue_work" sourceRef="action_gw" targetRef="end_active"/>

    <!-- Config change loop -->
    <bpmn:sequenceFlow id="flow_config_change" sourceRef="action_gw" targetRef="update_config_db">
      <bpmn:conditionExpression>action == "config_change"</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="flow_db_to_regen" sourceRef="update_config_db" targetRef="regenerate_files"/>
    <bpmn:sequenceFlow id="flow_regen_to_verify" sourceRef="regenerate_files" targetRef="verify_config"/>
    <bpmn:sequenceFlow id="flow_config_to_work" sourceRef="verify_config" targetRef="do_work"/>

    <!-- Phase advancement -->
    <bpmn:sequenceFlow id="flow_phase_advance" sourceRef="action_gw" targetRef="assess_and_advance_phase">
      <bpmn:conditionExpression>action == "phase_advance"</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="flow_advance_to_work" sourceRef="assess_and_advance_phase" targetRef="do_work"/>

    <!-- Retirement -->
    <bpmn:sequenceFlow id="flow_retire" sourceRef="action_gw" targetRef="archive_project">
      <bpmn:conditionExpression>action == "retire"</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="flow_archive_to_end" sourceRef="archive_project" targetRef="end_archived"/>

  </bpmn:process>

  <!-- ====================================================================== -->
  <!-- PROCESS 2: Phase Advancement (7-Stage Model + Gate Overlay)            -->
  <!--                                                                        -->
  <!-- Unified phase model merging project-ops (5 phases), phase-advance      -->
  <!-- (6 phases), and column_registry (6 values) into a single 7-stage       -->
  <!-- lifecycle. Metis gates overlay as optional quality checkpoints.         -->
  <!--                                                                        -->
  <!-- Stages: idea -> planning -> design -> implementation ->                -->
  <!--         testing -> production -> archived                              -->
  <!--                                                                        -->
  <!-- Gate overlay (optional, for structured projects):                       -->
  <!--   planning:       Gate 0 (understand problem), Gate 1 (understand domain) -->
  <!--   design:         Gate 2 (solution designed)                            -->
  <!--   implementation: Gate 3 (ready to build)                               -->
  <!--   testing:        Gate 4 (ready to release)                             -->
  <!--   production/archived: no gates (operational, not developmental)        -->
  <!--                                                                        -->
  <!-- Enforcement: Option C (Hybrid) - column_registry validates values,     -->
  <!-- skill documents transitions, no WorkflowEngine enforcement.            -->
  <!-- Phase changes via SQL in /phase-advance skill.                         -->
  <!-- ====================================================================== -->
  <bpmn:process id="phase_advancement" name="Phase Advancement: 7-Stage Unified Model" isExecutable="true">

    <bpmn:startEvent id="pa_start" name="Phase Advance Requested">
      <bpmn:outgoing>flow_pa_start</bpmn:outgoing>
    </bpmn:startEvent>

    <!-- Step 1: Get current phase from DB -->
    <bpmn:scriptTask id="get_current_phase" name="[DB] Get Current Phase" scriptFormat="python">
      <bpmn:incoming>flow_pa_start</bpmn:incoming>
      <bpmn:outgoing>flow_to_determine_next</bpmn:outgoing>
      <bpmn:script>
# SELECT phase FROM claude.projects WHERE project_name = project_name
# Valid phases: idea, planning, design, implementation, testing, production, archived
try:
    if current_phase is None:
        current_phase = "idea"
except NameError:
    current_phase = "idea"
      </bpmn:script>
    </bpmn:scriptTask>

    <!-- Step 2: Determine target phase -->
    <bpmn:userTask id="determine_next_phase" name="[CLAUDE] Determine Target Phase">
      <bpmn:incoming>flow_to_determine_next</bpmn:incoming>
      <bpmn:outgoing>flow_to_phase_gw</bpmn:outgoing>
    </bpmn:userTask>

    <!-- Step 3: Route to correct requirements check -->
    <bpmn:exclusiveGateway id="phase_target_gw" name="Target Phase?">
      <bpmn:incoming>flow_to_phase_gw</bpmn:incoming>
      <bpmn:outgoing>flow_to_planning</bpmn:outgoing>
      <bpmn:outgoing>flow_to_design</bpmn:outgoing>
      <bpmn:outgoing>flow_to_implementation</bpmn:outgoing>
      <bpmn:outgoing>flow_to_testing</bpmn:outgoing>
      <bpmn:outgoing>flow_to_production</bpmn:outgoing>
      <bpmn:outgoing>flow_to_archived</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <!-- ================================================================== -->
    <!-- PHASE REQUIREMENTS CHECKS                                          -->
    <!-- ================================================================== -->

    <!-- idea -> planning -->
    <bpmn:userTask id="check_planning_reqs" name="[CLAUDE] Check Planning Requirements">
      <bpmn:documentation>
        Requirements to enter PLANNING:
        - Problem statement exists (even rough)
        - User/stakeholder identified
        - Project registered in claude.projects
        Optional gate overlay: Gate 0 (understand problem)
      </bpmn:documentation>
      <bpmn:incoming>flow_to_planning</bpmn:incoming>
      <bpmn:outgoing>flow_planning_to_ready</bpmn:outgoing>
    </bpmn:userTask>

    <!-- planning -> design -->
    <bpmn:userTask id="check_design_reqs" name="[CLAUDE] Check Design Requirements">
      <bpmn:documentation>
        Requirements to enter DESIGN:
        - PROBLEM_STATEMENT.md complete
        - Success criteria defined
        - Constraints documented
        - At least one feature in claude.features
        Optional gate overlay: Gate 1 (understand domain)
      </bpmn:documentation>
      <bpmn:incoming>flow_to_design</bpmn:incoming>
      <bpmn:outgoing>flow_design_to_ready</bpmn:outgoing>
    </bpmn:userTask>

    <!-- design -> implementation -->
    <bpmn:userTask id="check_implementation_reqs" name="[CLAUDE] Check Implementation Requirements">
      <bpmn:documentation>
        Requirements to enter IMPLEMENTATION:
        - CLAUDE.md exists and is current
        - ARCHITECTURE.md exists
        - At least one feature with build tasks
        - Build tasks created for first feature
        Optional gate overlay: Gate 2 (solution designed)
      </bpmn:documentation>
      <bpmn:incoming>flow_to_implementation</bpmn:incoming>
      <bpmn:outgoing>flow_impl_to_ready</bpmn:outgoing>
    </bpmn:userTask>

    <!-- implementation -> testing -->
    <bpmn:userTask id="check_testing_reqs" name="[CLAUDE] Check Testing Requirements">
      <bpmn:documentation>
        Requirements to enter TESTING:
        - Core functionality complete
        - Unit tests exist and pass
        - No critical bugs open
        Optional gate overlay: Gate 3 (ready to build - all built)
      </bpmn:documentation>
      <bpmn:incoming>flow_to_testing</bpmn:incoming>
      <bpmn:outgoing>flow_testing_to_ready</bpmn:outgoing>
    </bpmn:userTask>

    <!-- testing -> production -->
    <bpmn:userTask id="check_production_reqs" name="[CLAUDE] Check Production Requirements">
      <bpmn:documentation>
        Requirements to enter PRODUCTION:
        - All tests passing
        - Documentation updated
        - All critical features completed
        - User has approved for production use
        Optional gate overlay: Gate 4 (ready to release)
      </bpmn:documentation>
      <bpmn:incoming>flow_to_production</bpmn:incoming>
      <bpmn:outgoing>flow_production_to_ready</bpmn:outgoing>
    </bpmn:userTask>

    <!-- production/any -> archived -->
    <bpmn:userTask id="check_archived_reqs" name="[CLAUDE] Check Archive Requirements">
      <bpmn:documentation>
        Requirements to ARCHIVE:
        - User confirms project should be archived
        - Final documentation updated
        - Archive reason documented
        - No gates apply (archival is an operational decision)
      </bpmn:documentation>
      <bpmn:incoming>flow_to_archived</bpmn:incoming>
      <bpmn:outgoing>flow_archived_to_ready</bpmn:outgoing>
    </bpmn:userTask>

    <!-- ================================================================== -->
    <!-- READINESS CHECK (all phase checks converge)                        -->
    <!-- ================================================================== -->

    <bpmn:exclusiveGateway id="ready_merge" name="Requirements Merge">
      <bpmn:incoming>flow_planning_to_ready</bpmn:incoming>
      <bpmn:incoming>flow_design_to_ready</bpmn:incoming>
      <bpmn:incoming>flow_impl_to_ready</bpmn:incoming>
      <bpmn:incoming>flow_testing_to_ready</bpmn:incoming>
      <bpmn:incoming>flow_production_to_ready</bpmn:incoming>
      <bpmn:incoming>flow_archived_to_ready</bpmn:incoming>
      <bpmn:outgoing>flow_to_ready_gw</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <bpmn:exclusiveGateway id="ready_gw" name="Requirements Met?" default="flow_not_ready">
      <bpmn:incoming>flow_to_ready_gw</bpmn:incoming>
      <bpmn:outgoing>flow_ready</bpmn:outgoing>
      <bpmn:outgoing>flow_not_ready</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <!-- Not ready: show gaps -->
    <bpmn:userTask id="show_gaps" name="[CLAUDE] Show Missing Requirements">
      <bpmn:incoming>flow_not_ready</bpmn:incoming>
      <bpmn:outgoing>flow_to_end_blocked</bpmn:outgoing>
    </bpmn:userTask>

    <bpmn:endEvent id="end_blocked" name="Phase Advance Blocked">
      <bpmn:incoming>flow_to_end_blocked</bpmn:incoming>
    </bpmn:endEvent>

    <!-- Ready: confirm and advance -->
    <bpmn:userTask id="confirm_advance" name="[CLAUDE] Confirm Phase Advance with User">
      <bpmn:incoming>flow_ready</bpmn:incoming>
      <bpmn:outgoing>flow_to_update_phase</bpmn:outgoing>
    </bpmn:userTask>

    <bpmn:scriptTask id="update_phase" name="[DB] Update Project Phase" scriptFormat="python">
      <bpmn:incoming>flow_to_update_phase</bpmn:incoming>
      <bpmn:outgoing>flow_to_end_advanced</bpmn:outgoing>
      <bpmn:script>
# UPDATE claude.projects SET phase = target_phase, updated_at = NOW()
# WHERE project_name = project_name
# Log transition in audit_log
phase_advanced = True
      </bpmn:script>
    </bpmn:scriptTask>

    <bpmn:endEvent id="end_advanced" name="Phase Advanced">
      <bpmn:incoming>flow_to_end_advanced</bpmn:incoming>
    </bpmn:endEvent>

    <!-- ================================================================== -->
    <!-- SEQUENCE FLOWS                                                     -->
    <!-- ================================================================== -->

    <bpmn:sequenceFlow id="flow_pa_start" sourceRef="pa_start" targetRef="get_current_phase"/>
    <bpmn:sequenceFlow id="flow_to_determine_next" sourceRef="get_current_phase" targetRef="determine_next_phase"/>
    <bpmn:sequenceFlow id="flow_to_phase_gw" sourceRef="determine_next_phase" targetRef="phase_target_gw"/>

    <!-- Target phase routing -->
    <bpmn:sequenceFlow id="flow_to_planning" sourceRef="phase_target_gw" targetRef="check_planning_reqs">
      <bpmn:conditionExpression>target_phase == "planning"</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="flow_to_design" sourceRef="phase_target_gw" targetRef="check_design_reqs">
      <bpmn:conditionExpression>target_phase == "design"</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="flow_to_implementation" sourceRef="phase_target_gw" targetRef="check_implementation_reqs">
      <bpmn:conditionExpression>target_phase == "implementation"</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="flow_to_testing" sourceRef="phase_target_gw" targetRef="check_testing_reqs">
      <bpmn:conditionExpression>target_phase == "testing"</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="flow_to_production" sourceRef="phase_target_gw" targetRef="check_production_reqs">
      <bpmn:conditionExpression>target_phase == "production"</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="flow_to_archived" sourceRef="phase_target_gw" targetRef="check_archived_reqs">
      <bpmn:conditionExpression>target_phase == "archived"</bpmn:conditionExpression>
    </bpmn:sequenceFlow>

    <!-- All checks merge -->
    <bpmn:sequenceFlow id="flow_planning_to_ready" sourceRef="check_planning_reqs" targetRef="ready_merge"/>
    <bpmn:sequenceFlow id="flow_design_to_ready" sourceRef="check_design_reqs" targetRef="ready_merge"/>
    <bpmn:sequenceFlow id="flow_impl_to_ready" sourceRef="check_implementation_reqs" targetRef="ready_merge"/>
    <bpmn:sequenceFlow id="flow_testing_to_ready" sourceRef="check_testing_reqs" targetRef="ready_merge"/>
    <bpmn:sequenceFlow id="flow_production_to_ready" sourceRef="check_production_reqs" targetRef="ready_merge"/>
    <bpmn:sequenceFlow id="flow_archived_to_ready" sourceRef="check_archived_reqs" targetRef="ready_merge"/>

    <!-- Readiness decision -->
    <bpmn:sequenceFlow id="flow_to_ready_gw" sourceRef="ready_merge" targetRef="ready_gw"/>
    <bpmn:sequenceFlow id="flow_ready" sourceRef="ready_gw" targetRef="confirm_advance">
      <bpmn:conditionExpression>requirements_met == True</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="flow_not_ready" sourceRef="ready_gw" targetRef="show_gaps"/>
    <bpmn:sequenceFlow id="flow_to_end_blocked" sourceRef="show_gaps" targetRef="end_blocked"/>

    <!-- Advance -->
    <bpmn:sequenceFlow id="flow_to_update_phase" sourceRef="confirm_advance" targetRef="update_phase"/>
    <bpmn:sequenceFlow id="flow_to_end_advanced" sourceRef="update_phase" targetRef="end_advanced"/>

  </bpmn:process>

  <bpmndi:BPMNDiagram id="BPMNDiagram_1">
    <bpmndi:BPMNPlane id="BPMNPlane_1" bpmnElement="project_lifecycle">
      <bpmndi:BPMNShape id="s_start" bpmnElement="start">
        <dc:Bounds x="50" y="300" width="36" height="36"/>
      </bpmndi:BPMNShape>
    </bpmndi:BPMNPlane>
  </bpmndi:BPMNDiagram>

</bpmn:definitions>
