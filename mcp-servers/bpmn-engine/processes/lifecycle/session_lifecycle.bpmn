<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions
    xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL"
    xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI"
    xmlns:dc="http://www.omg.org/spec/DD/20100524/DC"
    xmlns:di="http://www.omg.org/spec/DD/20100524/DI"
    targetNamespace="http://claude-family/bpmn/session-lifecycle"
    id="Definitions_SessionLifecycle">

  <bpmn:process id="session_lifecycle" name="Session Lifecycle" isExecutable="true">

    <!--
      Session lifecycle with full hook chain detail.

      Paths:
        1. Fresh session: start → auto_archive → session_start → check_messages → load_state
           → has_prior_state(False) → fresh_start → work_merge → do_work
           → work_action(end_session) → save_summary → close_session → end_normal
        2. Resumed session: ... → has_prior_state(True) → display_session_summary
           → has_prior_tasks → ... → work_merge → do_work
        3. Compact cycle: do_work → action(compact) → save_checkpoint → do_work (loop)
        4. Continue loop: do_work → action(continue/default) → do_work (loop)
        5. Auto-close: do_work → action(auto_close) → auto_close_session → end_auto

      Per-prompt hook chain inside do_work (every user prompt):
        UserPromptSubmit → rag_query_hook → RAG search + core protocol injection
        PreToolUse → task_discipline_hook + context_injector + standards_validator
        PostToolUse → todo_sync_hook + task_sync_hook + mcp_usage_logger

      Actors:
        [HOOK]  = scriptTask (automated hook operations)
        [MCP]   = scriptTask (MCP tool calls)
    -->

    <!-- Start Event -->
    <bpmn:startEvent id="start_event" name="Start">
      <bpmn:outgoing>flow_start_to_auto_archive</bpmn:outgoing>
    </bpmn:startEvent>

    <!-- Auto-archive old sessions (>24h) on startup before logging new session -->
    <bpmn:scriptTask id="auto_archive" name="[HOOK] Auto-Archive Old Sessions (&gt;24h)" scriptFormat="python">
      <bpmn:incoming>flow_start_to_auto_archive</bpmn:incoming>
      <bpmn:outgoing>flow_auto_archive_to_session_start</bpmn:outgoing>
      <bpmn:script>auto_archived = True</bpmn:script>
      <bpmn:documentation>session_startup_hook_enhanced.py auto-closes unclosed sessions older than 24h
via SessionEnd hook pattern before logging the new session. Prevents accumulation
of zombie sessions in claude.sessions table.</bpmn:documentation>
    </bpmn:scriptTask>

    <!-- Script Task: Session Start -->
    <bpmn:scriptTask id="session_start" name="[HOOK] Session Start (log to DB)" scriptFormat="python">
      <bpmn:incoming>flow_auto_archive_to_session_start</bpmn:incoming>
      <bpmn:outgoing>flow_session_start_to_check_messages</bpmn:outgoing>
      <bpmn:script>session_started = True</bpmn:script>
      <bpmn:documentation>session_startup_hook_enhanced.py fires on SessionStart event.
Logs new row to claude.sessions (60s dedup guard prevents duplicate entries).
Sets CLAUDE_SESSION_ID env var for subsequent hooks.</bpmn:documentation>
    </bpmn:scriptTask>

    <!-- Check inbox for pending messages before loading state -->
    <bpmn:scriptTask id="check_messages" name="[MCP] Check Inbox for Pending Messages" scriptFormat="python">
      <bpmn:incoming>flow_session_start_to_check_messages</bpmn:incoming>
      <bpmn:outgoing>flow_check_messages_to_load_state</bpmn:outgoing>
      <bpmn:script>messages_checked = True</bpmn:script>
      <bpmn:documentation>Calls check_inbox MCP tool to surface any pending messages from other
Claude instances or the orchestration system. Messages are displayed to Claude
at session start so they can be addressed immediately.</bpmn:documentation>
    </bpmn:scriptTask>

    <!-- User Task: Load State (user/test injects prior_state and state_loaded) -->
    <bpmn:userTask id="load_state" name="Load State">
      <bpmn:incoming>flow_check_messages_to_load_state</bpmn:incoming>
      <bpmn:outgoing>flow_load_state_to_prior_gateway</bpmn:outgoing>
    </bpmn:userTask>

    <!-- Exclusive Gateway: Has Prior State? -->
    <bpmn:exclusiveGateway id="has_prior_state_gateway" name="Has Prior State?" default="flow_fresh_start">
      <bpmn:incoming>flow_load_state_to_prior_gateway</bpmn:incoming>
      <bpmn:outgoing>flow_restore_context</bpmn:outgoing>
      <bpmn:outgoing>flow_fresh_start</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <!-- Script Task: Display Session Summary (read-only, no task restoration) -->
    <bpmn:scriptTask id="display_session_summary" name="Display Session Summary" scriptFormat="python">
      <bpmn:incoming>flow_restore_context</bpmn:incoming>
      <bpmn:outgoing>flow_summary_to_tasks_gw</bpmn:outgoing>
      <bpmn:script>context_displayed = True</bpmn:script>
      <bpmn:documentation>Shows pre-formatted resume box: last session summary, active features,
pending messages, git status. Display-only - does NOT restore tasks.
Rationale: Claude Code natively persists tasks in ~/.claude/tasks/.
DB todo restoration was creating zombie tasks carried forward indefinitely.</bpmn:documentation>
    </bpmn:scriptTask>

    <!-- Exclusive Gateway: Has Prior Tasks? -->
    <bpmn:exclusiveGateway id="has_prior_tasks_gateway" name="Has Prior Tasks?" default="flow_no_prior_tasks">
      <bpmn:incoming>flow_summary_to_tasks_gw</bpmn:incoming>
      <bpmn:outgoing>flow_display_prior_tasks</bpmn:outgoing>
      <bpmn:outgoing>flow_no_prior_tasks</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <!-- Script Task: Display Prior Tasks (read-only reference) -->
    <bpmn:scriptTask id="display_prior_tasks" name="Display Prior Tasks (Read-Only)" scriptFormat="python">
      <bpmn:incoming>flow_display_prior_tasks</bpmn:incoming>
      <bpmn:outgoing>flow_prior_tasks_to_merge</bpmn:outgoing>
      <bpmn:script>prior_tasks_displayed = True</bpmn:script>
      <bpmn:documentation>Shows previous session's open tasks as INFORMATIONAL text in the resume box.
Does NOT call TaskCreate. Does NOT restore them as active tasks.
User sees what was open and can manually re-create any tasks they want to continue.</bpmn:documentation>
    </bpmn:scriptTask>

    <!-- Exclusive Gateway: Prior Tasks Merge -->
    <bpmn:exclusiveGateway id="prior_tasks_merge" name="Prior Tasks Merge">
      <bpmn:incoming>flow_prior_tasks_to_merge</bpmn:incoming>
      <bpmn:incoming>flow_no_prior_tasks</bpmn:incoming>
      <bpmn:outgoing>flow_restore_to_merge</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <!-- Script Task: Fresh Start -->
    <bpmn:scriptTask id="fresh_start" name="Fresh Start" scriptFormat="python">
      <bpmn:incoming>flow_fresh_start</bpmn:incoming>
      <bpmn:outgoing>flow_fresh_to_merge</bpmn:outgoing>
      <bpmn:script>context = "fresh"</bpmn:script>
    </bpmn:scriptTask>

    <!-- Exclusive Gateway: Work Merge (converging) -->
    <bpmn:exclusiveGateway id="work_merge_gateway" name="Work Merge">
      <bpmn:incoming>flow_restore_to_merge</bpmn:incoming>
      <bpmn:incoming>flow_fresh_to_merge</bpmn:incoming>
      <bpmn:outgoing>flow_merge_to_rag</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <!-- Per-prompt RAG + Core Protocol injection (fires on every UserPromptSubmit) -->
    <bpmn:scriptTask id="rag_per_prompt" name="[HOOK] RAG + Core Protocol (per prompt)" scriptFormat="python">
      <bpmn:incoming>flow_merge_to_rag</bpmn:incoming>
      <bpmn:outgoing>flow_rag_to_do_work</bpmn:outgoing>
      <bpmn:script>rag_injected = True</bpmn:script>
      <bpmn:documentation>rag_query_hook.py fires on every UserPromptSubmit event.
1. Queries Voyage AI embeddings for vault docs relevant to the user prompt.
2. Injects core_protocol.txt (8 rules, ~30 tokens) prepended to every prompt.
3. Injects relevant vault excerpts and schema context as needed.
Lazy-loads voyageai client (~100ms saved on non-RAG prompts).</bpmn:documentation>
    </bpmn:scriptTask>

    <!-- User Task: Do Work -->
    <bpmn:userTask id="do_work" name="Do Work">
      <bpmn:incoming>flow_rag_to_do_work</bpmn:incoming>
      <bpmn:incoming>flow_checkpoint_to_do_work</bpmn:incoming>
      <bpmn:incoming>flow_continue_work</bpmn:incoming>
      <bpmn:outgoing>flow_do_work_to_action_gateway</bpmn:outgoing>
      <bpmn:documentation>Claude executes the user's request within the active session.
Per-prompt hook chain fires on every interaction:
  PreToolUse:  task_discipline_hook (blocks Write/Edit/Bash/Task if no tasks)
               context_injector_hook (injects coding standards)
               standards_validator (validates content conventions)
  PostToolUse: todo_sync_hook (syncs TodoWrite to claude.todos)
               task_sync_hook (syncs TaskCreate/Update to claude.todos + build_tasks)
               mcp_usage_logger (logs all MCP tool calls)
RAG+protocol injection occurs on each UserPromptSubmit via rag_per_prompt.</bpmn:documentation>
    </bpmn:userTask>

    <!-- Exclusive Gateway: Work Action -->
    <bpmn:exclusiveGateway id="work_action_gateway" name="Work Action" default="flow_continue_work">
      <bpmn:incoming>flow_do_work_to_action_gateway</bpmn:incoming>
      <bpmn:outgoing>flow_end_session</bpmn:outgoing>
      <bpmn:outgoing>flow_compact</bpmn:outgoing>
      <bpmn:outgoing>flow_continue_work</bpmn:outgoing>
      <bpmn:outgoing>flow_auto_close</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <!-- Script Task: Save Summary -->
    <bpmn:scriptTask id="save_summary" name="Save Summary" scriptFormat="python">
      <bpmn:incoming>flow_end_session</bpmn:incoming>
      <bpmn:outgoing>flow_save_summary_to_close</bpmn:outgoing>
      <bpmn:script>summary_saved = True</bpmn:script>
    </bpmn:scriptTask>

    <!-- Script Task: Close Session -->
    <bpmn:scriptTask id="close_session" name="Close Session" scriptFormat="python">
      <bpmn:incoming>flow_save_summary_to_close</bpmn:incoming>
      <bpmn:outgoing>flow_close_to_end_normal</bpmn:outgoing>
      <bpmn:script>session_closed = True</bpmn:script>
    </bpmn:scriptTask>

    <!-- Script Task: Save Checkpoint (PreCompact hook) -->
    <bpmn:scriptTask id="save_checkpoint" name="[HOOK] PreCompact: Inject Todos + Features + Facts + Notes" scriptFormat="python">
      <bpmn:incoming>flow_compact</bpmn:incoming>
      <bpmn:outgoing>flow_checkpoint_to_do_work</bpmn:outgoing>
      <bpmn:script>checkpoint_saved = True</bpmn:script>
      <bpmn:documentation>precompact_hook.py fires on PreCompact event (before context window compression).
Injects into the compaction context:
  - Active todos (from claude.todos where status IN ('pending','in_progress'))
  - Active features (from claude.features where status = 'in_progress')
  - Session facts (from claude.session_facts for current session_id)
  - Session notes (progress tracking content)
This ensures critical context survives compaction and is available post-compaction.</bpmn:documentation>
    </bpmn:scriptTask>

    <!-- Auto-close path: SessionEnd hook fires (not manual /session-end command) -->
    <bpmn:scriptTask id="auto_close_session" name="[HOOK] SessionEnd Auto-Close" scriptFormat="python">
      <bpmn:incoming>flow_auto_close</bpmn:incoming>
      <bpmn:outgoing>flow_auto_close_to_end</bpmn:outgoing>
      <bpmn:script>session_auto_closed = True</bpmn:script>
      <bpmn:documentation>session_end_hook.py fires on SessionEnd event (Claude process exits).
Auto-closes the session in claude.sessions without requiring manual /session-end.
Also triggers consolidate_memories() for cognitive memory lifecycle management.
Runs regardless of whether /session-end was called.</bpmn:documentation>
    </bpmn:scriptTask>

    <!-- End Event: Session Closed (manual /session-end) -->
    <bpmn:endEvent id="end_normal" name="Session Closed">
      <bpmn:incoming>flow_close_to_end_normal</bpmn:incoming>
    </bpmn:endEvent>

    <!-- End Event: Session Auto-Closed (hook-triggered) -->
    <bpmn:endEvent id="end_auto" name="Session Auto-Closed">
      <bpmn:incoming>flow_auto_close_to_end</bpmn:incoming>
    </bpmn:endEvent>

    <!-- Sequence Flows -->
    <bpmn:sequenceFlow id="flow_start_to_auto_archive" sourceRef="start_event" targetRef="auto_archive"/>
    <bpmn:sequenceFlow id="flow_auto_archive_to_session_start" sourceRef="auto_archive" targetRef="session_start"/>
    <bpmn:sequenceFlow id="flow_session_start_to_check_messages" sourceRef="session_start" targetRef="check_messages"/>
    <bpmn:sequenceFlow id="flow_check_messages_to_load_state" sourceRef="check_messages" targetRef="load_state"/>
    <bpmn:sequenceFlow id="flow_load_state_to_prior_gateway" sourceRef="load_state" targetRef="has_prior_state_gateway"/>

    <bpmn:sequenceFlow id="flow_restore_context" sourceRef="has_prior_state_gateway" targetRef="display_session_summary">
      <bpmn:conditionExpression>prior_state == True</bpmn:conditionExpression>
    </bpmn:sequenceFlow>

    <bpmn:sequenceFlow id="flow_fresh_start" sourceRef="has_prior_state_gateway" targetRef="fresh_start"/>

    <!-- New flows for expanded restore sub-flow -->
    <bpmn:sequenceFlow id="flow_summary_to_tasks_gw" sourceRef="display_session_summary" targetRef="has_prior_tasks_gateway"/>

    <bpmn:sequenceFlow id="flow_display_prior_tasks" sourceRef="has_prior_tasks_gateway" targetRef="display_prior_tasks">
      <bpmn:conditionExpression>has_prior_tasks == True</bpmn:conditionExpression>
    </bpmn:sequenceFlow>

    <bpmn:sequenceFlow id="flow_no_prior_tasks" sourceRef="has_prior_tasks_gateway" targetRef="prior_tasks_merge"/>

    <bpmn:sequenceFlow id="flow_prior_tasks_to_merge" sourceRef="display_prior_tasks" targetRef="prior_tasks_merge"/>

    <bpmn:sequenceFlow id="flow_restore_to_merge" sourceRef="prior_tasks_merge" targetRef="work_merge_gateway"/>
    <bpmn:sequenceFlow id="flow_fresh_to_merge" sourceRef="fresh_start" targetRef="work_merge_gateway"/>
    <bpmn:sequenceFlow id="flow_merge_to_rag" sourceRef="work_merge_gateway" targetRef="rag_per_prompt"/>
    <bpmn:sequenceFlow id="flow_rag_to_do_work" sourceRef="rag_per_prompt" targetRef="do_work"/>
    <bpmn:sequenceFlow id="flow_do_work_to_action_gateway" sourceRef="do_work" targetRef="work_action_gateway"/>

    <bpmn:sequenceFlow id="flow_end_session" sourceRef="work_action_gateway" targetRef="save_summary">
      <bpmn:conditionExpression>action == "end_session"</bpmn:conditionExpression>
    </bpmn:sequenceFlow>

    <bpmn:sequenceFlow id="flow_compact" sourceRef="work_action_gateway" targetRef="save_checkpoint">
      <bpmn:conditionExpression>action == "compact"</bpmn:conditionExpression>
    </bpmn:sequenceFlow>

    <bpmn:sequenceFlow id="flow_auto_close" sourceRef="work_action_gateway" targetRef="auto_close_session">
      <bpmn:conditionExpression>action == "auto_close"</bpmn:conditionExpression>
    </bpmn:sequenceFlow>

    <bpmn:sequenceFlow id="flow_continue_work" sourceRef="work_action_gateway" targetRef="do_work"/>

    <bpmn:sequenceFlow id="flow_save_summary_to_close" sourceRef="save_summary" targetRef="close_session"/>
    <bpmn:sequenceFlow id="flow_close_to_end_normal" sourceRef="close_session" targetRef="end_normal"/>
    <bpmn:sequenceFlow id="flow_checkpoint_to_do_work" sourceRef="save_checkpoint" targetRef="do_work"/>
    <bpmn:sequenceFlow id="flow_auto_close_to_end" sourceRef="auto_close_session" targetRef="end_auto"/>

  </bpmn:process>

  <!-- Diagram layout -->
  <bpmndi:BPMNDiagram id="BPMNDiagram_1">
    <bpmndi:BPMNPlane id="BPMNPlane_1" bpmnElement="session_lifecycle">

      <!-- Row 1 (y=200): main flow left-to-right -->
      <bpmndi:BPMNShape id="shape_start_event" bpmnElement="start_event">
        <dc:Bounds x="60" y="200" width="36" height="36"/>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="shape_auto_archive" bpmnElement="auto_archive">
        <dc:Bounds x="160" y="180" width="120" height="80"/>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="shape_session_start" bpmnElement="session_start">
        <dc:Bounds x="340" y="180" width="120" height="80"/>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="shape_check_messages" bpmnElement="check_messages">
        <dc:Bounds x="520" y="180" width="120" height="80"/>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="shape_load_state" bpmnElement="load_state">
        <dc:Bounds x="700" y="180" width="100" height="80"/>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="shape_has_prior_state_gateway" bpmnElement="has_prior_state_gateway" isMarkerVisible="true">
        <dc:Bounds x="860" y="193" width="50" height="50"/>
      </bpmndi:BPMNShape>

      <!-- Expanded restore context sub-flow (above main row) -->
      <bpmndi:BPMNShape id="shape_display_session_summary" bpmnElement="display_session_summary">
        <dc:Bounds x="940" y="60" width="120" height="80"/>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="shape_has_prior_tasks_gateway" bpmnElement="has_prior_tasks_gateway" isMarkerVisible="true">
        <dc:Bounds x="1100" y="73" width="50" height="50"/>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="shape_display_prior_tasks" bpmnElement="display_prior_tasks">
        <dc:Bounds x="1190" y="20" width="120" height="80"/>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="shape_prior_tasks_merge" bpmnElement="prior_tasks_merge" isMarkerVisible="true">
        <dc:Bounds x="1350" y="73" width="50" height="50"/>
      </bpmndi:BPMNShape>

      <!-- fresh_start branch (y=340 - below main row) -->
      <bpmndi:BPMNShape id="shape_fresh_start" bpmnElement="fresh_start">
        <dc:Bounds x="940" y="340" width="100" height="80"/>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="shape_work_merge_gateway" bpmnElement="work_merge_gateway" isMarkerVisible="true">
        <dc:Bounds x="1440" y="193" width="50" height="50"/>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="shape_rag_per_prompt" bpmnElement="rag_per_prompt">
        <dc:Bounds x="1550" y="180" width="120" height="80"/>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="shape_do_work" bpmnElement="do_work">
        <dc:Bounds x="1730" y="180" width="100" height="80"/>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="shape_work_action_gateway" bpmnElement="work_action_gateway" isMarkerVisible="true">
        <dc:Bounds x="1900" y="193" width="50" height="50"/>
      </bpmndi:BPMNShape>

      <!-- end_session branch (right) -->
      <bpmndi:BPMNShape id="shape_save_summary" bpmnElement="save_summary">
        <dc:Bounds x="2010" y="180" width="100" height="80"/>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="shape_close_session" bpmnElement="close_session">
        <dc:Bounds x="2170" y="180" width="100" height="80"/>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="shape_end_normal" bpmnElement="end_normal">
        <dc:Bounds x="2334" y="200" width="36" height="36"/>
      </bpmndi:BPMNShape>

      <!-- save_checkpoint (compact branch, below) -->
      <bpmndi:BPMNShape id="shape_save_checkpoint" bpmnElement="save_checkpoint">
        <dc:Bounds x="1870" y="340" width="160" height="80"/>
      </bpmndi:BPMNShape>

      <!-- auto_close branch (above) -->
      <bpmndi:BPMNShape id="shape_auto_close_session" bpmnElement="auto_close_session">
        <dc:Bounds x="2010" y="60" width="120" height="80"/>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="shape_end_auto" bpmnElement="end_auto">
        <dc:Bounds x="2190" y="80" width="36" height="36"/>
      </bpmndi:BPMNShape>

      <!-- Edges -->
      <bpmndi:BPMNEdge id="edge_flow_start_to_auto_archive" bpmnElement="flow_start_to_auto_archive">
        <di:waypoint x="96" y="218"/>
        <di:waypoint x="160" y="220"/>
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="edge_flow_auto_archive_to_session_start" bpmnElement="flow_auto_archive_to_session_start">
        <di:waypoint x="280" y="220"/>
        <di:waypoint x="340" y="220"/>
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="edge_flow_session_start_to_check_messages" bpmnElement="flow_session_start_to_check_messages">
        <di:waypoint x="460" y="220"/>
        <di:waypoint x="520" y="220"/>
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="edge_flow_check_messages_to_load_state" bpmnElement="flow_check_messages_to_load_state">
        <di:waypoint x="640" y="220"/>
        <di:waypoint x="700" y="220"/>
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="edge_flow_load_state_to_prior_gateway" bpmnElement="flow_load_state_to_prior_gateway">
        <di:waypoint x="800" y="220"/>
        <di:waypoint x="860" y="218"/>
      </bpmndi:BPMNEdge>

      <!-- has_prior_state_gateway → display_session_summary (up branch) -->
      <bpmndi:BPMNEdge id="edge_flow_restore_context" bpmnElement="flow_restore_context">
        <di:waypoint x="885" y="193"/>
        <di:waypoint x="885" y="100"/>
        <di:waypoint x="940" y="100"/>
      </bpmndi:BPMNEdge>

      <!-- has_prior_state_gateway → fresh_start (down branch / default) -->
      <bpmndi:BPMNEdge id="edge_flow_fresh_start" bpmnElement="flow_fresh_start">
        <di:waypoint x="885" y="243"/>
        <di:waypoint x="885" y="380"/>
        <di:waypoint x="940" y="380"/>
      </bpmndi:BPMNEdge>

      <!-- display_session_summary → has_prior_tasks_gateway -->
      <bpmndi:BPMNEdge id="edge_flow_summary_to_tasks_gw" bpmnElement="flow_summary_to_tasks_gw">
        <di:waypoint x="1060" y="100"/>
        <di:waypoint x="1100" y="98"/>
      </bpmndi:BPMNEdge>

      <!-- has_prior_tasks_gateway → display_prior_tasks (up) -->
      <bpmndi:BPMNEdge id="edge_flow_display_prior_tasks" bpmnElement="flow_display_prior_tasks">
        <di:waypoint x="1125" y="73"/>
        <di:waypoint x="1125" y="60"/>
        <di:waypoint x="1190" y="60"/>
      </bpmndi:BPMNEdge>

      <!-- has_prior_tasks_gateway → prior_tasks_merge (default, skip) -->
      <bpmndi:BPMNEdge id="edge_flow_no_prior_tasks" bpmnElement="flow_no_prior_tasks">
        <di:waypoint x="1150" y="98"/>
        <di:waypoint x="1350" y="98"/>
      </bpmndi:BPMNEdge>

      <!-- display_prior_tasks → prior_tasks_merge -->
      <bpmndi:BPMNEdge id="edge_flow_prior_tasks_to_merge" bpmnElement="flow_prior_tasks_to_merge">
        <di:waypoint x="1310" y="60"/>
        <di:waypoint x="1375" y="60"/>
        <di:waypoint x="1375" y="73"/>
      </bpmndi:BPMNEdge>

      <!-- prior_tasks_merge → work_merge_gateway -->
      <bpmndi:BPMNEdge id="edge_flow_restore_to_merge" bpmnElement="flow_restore_to_merge">
        <di:waypoint x="1400" y="98"/>
        <di:waypoint x="1465" y="98"/>
        <di:waypoint x="1465" y="193"/>
      </bpmndi:BPMNEdge>

      <!-- fresh_start → work_merge_gateway -->
      <bpmndi:BPMNEdge id="edge_flow_fresh_to_merge" bpmnElement="flow_fresh_to_merge">
        <di:waypoint x="1040" y="380"/>
        <di:waypoint x="1465" y="380"/>
        <di:waypoint x="1465" y="243"/>
      </bpmndi:BPMNEdge>

      <!-- work_merge_gateway → rag_per_prompt -->
      <bpmndi:BPMNEdge id="edge_flow_merge_to_rag" bpmnElement="flow_merge_to_rag">
        <di:waypoint x="1490" y="218"/>
        <di:waypoint x="1550" y="220"/>
      </bpmndi:BPMNEdge>

      <!-- rag_per_prompt → do_work -->
      <bpmndi:BPMNEdge id="edge_flow_rag_to_do_work" bpmnElement="flow_rag_to_do_work">
        <di:waypoint x="1670" y="220"/>
        <di:waypoint x="1730" y="220"/>
      </bpmndi:BPMNEdge>

      <!-- do_work → work_action_gateway -->
      <bpmndi:BPMNEdge id="edge_flow_do_work_to_action_gateway" bpmnElement="flow_do_work_to_action_gateway">
        <di:waypoint x="1830" y="220"/>
        <di:waypoint x="1900" y="218"/>
      </bpmndi:BPMNEdge>

      <!-- work_action_gateway → save_summary (end_session branch) -->
      <bpmndi:BPMNEdge id="edge_flow_end_session" bpmnElement="flow_end_session">
        <di:waypoint x="1950" y="218"/>
        <di:waypoint x="2010" y="220"/>
      </bpmndi:BPMNEdge>

      <!-- work_action_gateway → save_checkpoint (compact branch) -->
      <bpmndi:BPMNEdge id="edge_flow_compact" bpmnElement="flow_compact">
        <di:waypoint x="1925" y="243"/>
        <di:waypoint x="1925" y="380"/>
        <di:waypoint x="1870" y="380"/>
      </bpmndi:BPMNEdge>

      <!-- work_action_gateway → auto_close_session (auto_close branch) -->
      <bpmndi:BPMNEdge id="edge_flow_auto_close" bpmnElement="flow_auto_close">
        <di:waypoint x="1925" y="193"/>
        <di:waypoint x="1925" y="100"/>
        <di:waypoint x="2010" y="100"/>
      </bpmndi:BPMNEdge>

      <!-- work_action_gateway → do_work (continue_work / default loop back) -->
      <bpmndi:BPMNEdge id="edge_flow_continue_work" bpmnElement="flow_continue_work">
        <di:waypoint x="1925" y="193"/>
        <di:waypoint x="1925" y="140"/>
        <di:waypoint x="1780" y="140"/>
        <di:waypoint x="1780" y="180"/>
      </bpmndi:BPMNEdge>

      <!-- save_summary → close_session -->
      <bpmndi:BPMNEdge id="edge_flow_save_summary_to_close" bpmnElement="flow_save_summary_to_close">
        <di:waypoint x="2110" y="220"/>
        <di:waypoint x="2170" y="220"/>
      </bpmndi:BPMNEdge>

      <!-- close_session → end_normal -->
      <bpmndi:BPMNEdge id="edge_flow_close_to_end_normal" bpmnElement="flow_close_to_end_normal">
        <di:waypoint x="2270" y="220"/>
        <di:waypoint x="2334" y="218"/>
      </bpmndi:BPMNEdge>

      <!-- save_checkpoint → do_work (compact loop back) -->
      <bpmndi:BPMNEdge id="edge_flow_checkpoint_to_do_work" bpmnElement="flow_checkpoint_to_do_work">
        <di:waypoint x="1870" y="380"/>
        <di:waypoint x="1780" y="380"/>
        <di:waypoint x="1780" y="260"/>
      </bpmndi:BPMNEdge>

      <!-- auto_close_session → end_auto -->
      <bpmndi:BPMNEdge id="edge_flow_auto_close_to_end" bpmnElement="flow_auto_close_to_end">
        <di:waypoint x="2130" y="98"/>
        <di:waypoint x="2190" y="98"/>
      </bpmndi:BPMNEdge>

    </bpmndi:BPMNPlane>
  </bpmndi:BPMNDiagram>

</bpmn:definitions>
