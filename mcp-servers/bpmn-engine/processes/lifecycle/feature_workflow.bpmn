<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions
    xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL"
    xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI"
    xmlns:dc="http://www.omg.org/spec/DD/20100524/DC"
    xmlns:di="http://www.omg.org/spec/DD/20100524/DI"
    targetNamespace="http://claude-family/bpmn/feature-workflow"
    id="Definitions_FeatureWorkflow">

  <bpmn:process id="feature_workflow" name="Feature Workflow" isExecutable="true">

    <!--
      Feature lifecycle from idea to completion.

      Flow:
        create_feature → set_draft → plan_feature [stores plan_data JSONB]
          → set_planned → create_build_tasks → set_in_progress
          → complexity_gateway
              [complexity=="high"] → spawn_agents → implementation_merge
              [default/simple]     → implement_directly
                  → next_task_gw → start_task → implement_task → complete_task
                  → more_tasks_gw → [yes: loop] / [no: implementation_merge]
          → run_tests [SHOULD BE ENFORCED: stop hook checks 3+ file changes]
          → tests_pass_gateway
              [tests_passed==True] → review_code [SHOULD BE ENFORCED: spawn reviewer-sonnet]
                  → review_result_gateway
                      [review=="changes_requested"] → fix_issues_review → run_tests (loop)
                      [default/approved]            → set_completed → end_completed
              [default/fail]       → fix_issues → run_tests (loop)

      Actors:
        [CLAUDE] = userTask (decisions, implementation)
        [DB]     = scriptTask (database status transitions)
        [MCP]    = scriptTask (MCP tool calls)
    -->

    <!-- Start Event -->
    <bpmn:startEvent id="start_event" name="Start">
      <bpmn:outgoing>flow_start_to_create</bpmn:outgoing>
    </bpmn:startEvent>

    <!-- User Task: Create Feature -->
    <bpmn:userTask id="create_feature" name="Create Feature">
      <bpmn:incoming>flow_start_to_create</bpmn:incoming>
      <bpmn:outgoing>flow_create_to_set_draft</bpmn:outgoing>
    </bpmn:userTask>

    <!-- Script Task: Set Draft -->
    <bpmn:scriptTask id="set_draft" name="Set Draft" scriptFormat="python">
      <bpmn:incoming>flow_create_to_set_draft</bpmn:incoming>
      <bpmn:outgoing>flow_set_draft_to_plan</bpmn:outgoing>
      <bpmn:script>status = "draft"</bpmn:script>
    </bpmn:scriptTask>

    <!-- User Task: Plan Feature -->
    <bpmn:userTask id="plan_feature" name="Plan Feature">
      <bpmn:incoming>flow_set_draft_to_plan</bpmn:incoming>
      <bpmn:outgoing>flow_plan_to_set_planned</bpmn:outgoing>
      <bpmn:documentation>Claude plans the feature and stores the plan.
Outputs are stored as plan_data JSONB in claude.features.plan_data:
  - requirements: list of acceptance criteria
  - risks: identified risks and mitigations
  - implementation_specs: step-by-step implementation details
  - complexity: 'simple' or 'high' (drives complexity_gateway)
Use work_create(type="task") to add build tasks after planning.</bpmn:documentation>
    </bpmn:userTask>

    <!-- Script Task: Set Planned -->
    <bpmn:scriptTask id="set_planned" name="Set Planned" scriptFormat="python">
      <bpmn:incoming>flow_plan_to_set_planned</bpmn:incoming>
      <bpmn:outgoing>flow_set_planned_to_create_tasks</bpmn:outgoing>
      <bpmn:script>status = "planned"</bpmn:script>
    </bpmn:scriptTask>

    <!-- User Task: Create Build Tasks -->
    <bpmn:userTask id="create_build_tasks" name="[CLAUDE] Create Build Tasks (work_create(type=&quot;task&quot;))">
      <bpmn:incoming>flow_set_planned_to_create_tasks</bpmn:incoming>
      <bpmn:outgoing>flow_create_tasks_to_set_in_progress</bpmn:outgoing>
      <bpmn:documentation>Claude creates build tasks using work_create(type="task") MCP tool.
Each task should have: name, description, verification criteria, files_affected.
Tasks are linked to the feature via feature_code (e.g., F42).
After creation, tasks appear in claude.build_tasks with status='todo'.</bpmn:documentation>
    </bpmn:userTask>

    <!-- Script Task: Set In Progress -->
    <bpmn:scriptTask id="set_in_progress" name="[DB] Set Feature In Progress" scriptFormat="python">
      <bpmn:incoming>flow_create_tasks_to_set_in_progress</bpmn:incoming>
      <bpmn:outgoing>flow_set_in_progress_to_complexity</bpmn:outgoing>
      <bpmn:script>status = "in_progress"</bpmn:script>
      <bpmn:documentation>Transitions feature status from 'planned' to 'in_progress' via WorkflowEngine.
Uses work_status(action="advance") MCP tool internally. Transition logged to claude.audit_log.</bpmn:documentation>
    </bpmn:scriptTask>

    <!-- Exclusive Gateway: Complexity Check -->
    <bpmn:exclusiveGateway id="complexity_gateway" name="High Complexity?" default="flow_simple">
      <bpmn:incoming>flow_set_in_progress_to_complexity</bpmn:incoming>
      <bpmn:outgoing>flow_high_complexity</bpmn:outgoing>
      <bpmn:outgoing>flow_simple</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <!-- User Task: Spawn Agents (high complexity path) -->
    <bpmn:userTask id="spawn_agents" name="Spawn Agents">
      <bpmn:incoming>flow_high_complexity</bpmn:incoming>
      <bpmn:outgoing>flow_spawn_to_merge</bpmn:outgoing>
      <bpmn:documentation>For high-complexity features, Claude spawns sub-agents via native Task tool.
Each agent handles a subset of build tasks. Agents use work_status(action="start") / work_status(action="complete")
MCP tools to track progress. After all agents complete, implementation_merge
gateway consolidates results into the test phase.</bpmn:documentation>
    </bpmn:userTask>

    <!-- User Task: Implement Directly (simple path entry point) -->
    <bpmn:userTask id="implement_directly" name="Implement Directly">
      <bpmn:incoming>flow_simple</bpmn:incoming>
      <bpmn:outgoing>flow_implement_to_next_task</bpmn:outgoing>
      <bpmn:documentation>For simple features, Claude implements directly without spawning agents.
Execution proceeds through the per-task work loop (next_task_gw → start_task
→ implement_task → complete_task → more_tasks_gw) for each build task.</bpmn:documentation>
    </bpmn:userTask>

    <!-- ================================================================== -->
    <!-- PER-TASK WORK LOOP (simple path)                                    -->
    <!-- ================================================================== -->

    <!-- Gateway: Is there a next task to work on? -->
    <bpmn:exclusiveGateway id="next_task_gw" name="Next Task?" default="flow_no_next_task">
      <bpmn:incoming>flow_implement_to_next_task</bpmn:incoming>
      <bpmn:incoming>flow_rollup_not_ready</bpmn:incoming>
      <bpmn:outgoing>flow_has_next_task</bpmn:outgoing>
      <bpmn:outgoing>flow_no_next_task</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <!-- Script Task: Start the next build task -->
    <bpmn:scriptTask id="start_task" name="[MCP] work_status(action=&quot;start&quot;, task_code)" scriptFormat="python">
      <bpmn:incoming>flow_has_next_task</bpmn:incoming>
      <bpmn:outgoing>flow_start_task_to_implement</bpmn:outgoing>
      <bpmn:script>task_started = True</bpmn:script>
      <bpmn:documentation>Calls work_status(action="start",task_code) MCP tool to transition build task
from 'todo' to 'in_progress' via WorkflowEngine state machine.
Loads plan_data context for the task into Claude's working memory.</bpmn:documentation>
    </bpmn:scriptTask>

    <!-- User Task: Implement the current task -->
    <bpmn:userTask id="implement_task" name="[CLAUDE] Implement Task">
      <bpmn:incoming>flow_start_task_to_implement</bpmn:incoming>
      <bpmn:outgoing>flow_implement_task_to_complete</bpmn:outgoing>
    </bpmn:userTask>

    <!-- Script Task: Complete the current task -->
    <bpmn:scriptTask id="complete_task" name="[MCP] work_status(action=&quot;complete&quot;, task_code)" scriptFormat="python">
      <bpmn:incoming>flow_implement_task_to_complete</bpmn:incoming>
      <bpmn:outgoing>flow_complete_task_to_rollup_check</bpmn:outgoing>
      <bpmn:script>task_completed = True
# F209: default rollup signals. Real WorkflowEngine implementation computes these
# from DB state (remaining sibling tasks, feature status). Defaulting here keeps
# the per-task loop test path (has_next_task=False at next_task_gw) working when
# auto-rollup is not exercised.
try:
    all_tasks_complete
except NameError:
    all_tasks_complete = False
try:
    feature_status
except NameError:
    feature_status = "in_progress"</bpmn:script>
      <bpmn:documentation>Calls work_status(action="complete",task_code) MCP tool to transition build task
from 'in_progress' to 'completed'. After the transition, control flows to
rollup_check_gw which decides whether the parent feature auto-advances.
The WorkflowEngine side-effect computes all_tasks_complete and feature_status
from DB state; the defaults here keep the simulation stable when those are
not explicitly provided.</bpmn:documentation>
    </bpmn:scriptTask>

    <!-- ================================================================== -->
    <!-- AUTO-ROLLUP PATH (F209): on last task complete, advance feature     -->
    <!-- ================================================================== -->

    <!-- Gateway: Should parent feature auto-rollup? -->
    <bpmn:exclusiveGateway id="rollup_check_gw" name="All Tasks Done &amp; Feature In Progress?" default="flow_rollup_not_ready">
      <bpmn:incoming>flow_complete_task_to_rollup_check</bpmn:incoming>
      <bpmn:outgoing>flow_rollup_ready</bpmn:outgoing>
      <bpmn:outgoing>flow_rollup_not_ready</bpmn:outgoing>
      <bpmn:documentation>F209: Auto-rollup policy gateway.
Condition for rollup_ready: all_tasks_complete == True AND feature_status == "in_progress".
If feature_status == "planned", rollup is deferred to the nightly sweep (per-project policy may differ).
Cancelled tasks count as complete for this decision.
not_ready is the default branch (returns to per-task loop).</bpmn:documentation>
    </bpmn:exclusiveGateway>

    <!-- Script Task: Auto-advance feature to completed -->
    <bpmn:scriptTask id="auto_rollup_feature" name="[DB] Auto-Advance Feature to Completed" scriptFormat="python">
      <bpmn:incoming>flow_rollup_ready</bpmn:incoming>
      <bpmn:outgoing>flow_auto_rollup_to_end</bpmn:outgoing>
      <bpmn:script>status = "completed"
change_source = "auto_rollup"</bpmn:script>
      <bpmn:documentation>Administrative auto-rollup path (distinct from the ceremonial review path).
Calls WorkflowEngine.execute_transition(entity_type="features", item_id=feature_code,
new_status="completed", change_source="auto_rollup", metadata={"reason":"all_children_completed"}).
Logs to claude.audit_log. If the feature has a parent stream, recursively checks
whether the stream is now ready to roll up as well.
Note: run_tests and review_code are quality gates that should have happened per-task
or out-of-band. This scriptTask only flips the feature status record.</bpmn:documentation>
    </bpmn:scriptTask>

    <!-- End Event: Auto-Rollup Completed -->
    <bpmn:endEvent id="end_auto_rollup" name="Feature Auto-Rolled Up">
      <bpmn:incoming>flow_auto_rollup_to_end</bpmn:incoming>
    </bpmn:endEvent>

    <!-- ================================================================== -->
    <!-- END OF PER-TASK LOOP                                               -->
    <!-- ================================================================== -->

    <!-- Exclusive Gateway: Implementation Merge -->
    <bpmn:exclusiveGateway id="implementation_merge" name="Implementation Merge">
      <bpmn:incoming>flow_spawn_to_merge</bpmn:incoming>
      <bpmn:incoming>flow_no_next_task</bpmn:incoming>
      <bpmn:outgoing>flow_merge_to_run_tests</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <!-- User Task: Run Tests -->
    <bpmn:userTask id="run_tests" name="Run Tests">
      <bpmn:incoming>flow_merge_to_run_tests</bpmn:incoming>
      <bpmn:incoming>flow_fix_to_run_tests</bpmn:incoming>
      <bpmn:incoming>flow_fix_review_to_run_tests</bpmn:incoming>
      <bpmn:outgoing>flow_run_tests_to_gateway</bpmn:outgoing>
      <bpmn:documentation>SHOULD BE ENFORCED: Currently optional in practice.
Stop hook checks 3+ file changes and reminds Claude to run tests.
Use: pytest path/to/tests -v (Python), npm test (JS), dotnet test (C#).
Coverage: happy path + edge cases for new code, regression test for fixes.</bpmn:documentation>
    </bpmn:userTask>

    <!-- Exclusive Gateway: Tests Pass? -->
    <bpmn:exclusiveGateway id="tests_pass_gateway" name="Tests Pass?" default="flow_tests_fail">
      <bpmn:incoming>flow_run_tests_to_gateway</bpmn:incoming>
      <bpmn:outgoing>flow_tests_pass</bpmn:outgoing>
      <bpmn:outgoing>flow_tests_fail</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <!-- User Task: Fix Issues (from test failure) -->
    <bpmn:userTask id="fix_issues" name="Fix Issues">
      <bpmn:incoming>flow_tests_fail</bpmn:incoming>
      <bpmn:outgoing>flow_fix_to_run_tests</bpmn:outgoing>
    </bpmn:userTask>

    <!-- User Task: Review Code -->
    <bpmn:userTask id="review_code" name="Review Code">
      <bpmn:incoming>flow_tests_pass</bpmn:incoming>
      <bpmn:outgoing>flow_review_to_result_gateway</bpmn:outgoing>
      <bpmn:documentation>SHOULD BE ENFORCED: Spawn reviewer-sonnet agent for code review.
Currently advisory only - Claude may self-review or skip on simple changes.
Reviewer checks: correctness, convention adherence, test coverage, security.
Use Task tool to delegate: Task("reviewer-sonnet", "Review changes in ...")</bpmn:documentation>
    </bpmn:userTask>

    <!-- Exclusive Gateway: Review Result -->
    <bpmn:exclusiveGateway id="review_result_gateway" name="Review Result?" default="flow_approved">
      <bpmn:incoming>flow_review_to_result_gateway</bpmn:incoming>
      <bpmn:outgoing>flow_changes_requested</bpmn:outgoing>
      <bpmn:outgoing>flow_approved</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <!-- User Task: Fix Issues Review (from review changes requested) -->
    <bpmn:userTask id="fix_issues_review" name="Fix Issues (Review)">
      <bpmn:incoming>flow_changes_requested</bpmn:incoming>
      <bpmn:outgoing>flow_fix_review_to_run_tests</bpmn:outgoing>
    </bpmn:userTask>

    <!-- Script Task: Set Completed -->
    <bpmn:scriptTask id="set_completed" name="Set Completed" scriptFormat="python">
      <bpmn:incoming>flow_approved</bpmn:incoming>
      <bpmn:outgoing>flow_set_completed_to_end</bpmn:outgoing>
      <bpmn:script>status = "completed"</bpmn:script>
    </bpmn:scriptTask>

    <!-- End Event: Feature Completed -->
    <bpmn:endEvent id="end_completed" name="Feature Completed">
      <bpmn:incoming>flow_set_completed_to_end</bpmn:incoming>
    </bpmn:endEvent>

    <!-- Sequence Flows -->
    <bpmn:sequenceFlow id="flow_start_to_create" sourceRef="start_event" targetRef="create_feature"/>
    <bpmn:sequenceFlow id="flow_create_to_set_draft" sourceRef="create_feature" targetRef="set_draft"/>
    <bpmn:sequenceFlow id="flow_set_draft_to_plan" sourceRef="set_draft" targetRef="plan_feature"/>
    <bpmn:sequenceFlow id="flow_plan_to_set_planned" sourceRef="plan_feature" targetRef="set_planned"/>
    <bpmn:sequenceFlow id="flow_set_planned_to_create_tasks" sourceRef="set_planned" targetRef="create_build_tasks"/>
    <bpmn:sequenceFlow id="flow_create_tasks_to_set_in_progress" sourceRef="create_build_tasks" targetRef="set_in_progress"/>
    <bpmn:sequenceFlow id="flow_set_in_progress_to_complexity" sourceRef="set_in_progress" targetRef="complexity_gateway"/>

    <bpmn:sequenceFlow id="flow_high_complexity" sourceRef="complexity_gateway" targetRef="spawn_agents">
      <bpmn:conditionExpression>complexity == "high"</bpmn:conditionExpression>
    </bpmn:sequenceFlow>

    <bpmn:sequenceFlow id="flow_simple" sourceRef="complexity_gateway" targetRef="implement_directly"/>

    <!-- Simple path: implement_directly → per-task loop -->
    <bpmn:sequenceFlow id="flow_implement_to_next_task" sourceRef="implement_directly" targetRef="next_task_gw"/>

    <!-- Per-task loop flows -->
    <bpmn:sequenceFlow id="flow_has_next_task" sourceRef="next_task_gw" targetRef="start_task">
      <bpmn:conditionExpression>has_next_task == True</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="flow_no_next_task" sourceRef="next_task_gw" targetRef="implementation_merge"/>
    <bpmn:sequenceFlow id="flow_start_task_to_implement" sourceRef="start_task" targetRef="implement_task"/>
    <bpmn:sequenceFlow id="flow_implement_task_to_complete" sourceRef="implement_task" targetRef="complete_task"/>
    <!-- F209: complete_task now flows into the rollup gateway, not directly to next_task_gw -->
    <bpmn:sequenceFlow id="flow_complete_task_to_rollup_check" sourceRef="complete_task" targetRef="rollup_check_gw"/>

    <bpmn:sequenceFlow id="flow_rollup_ready" sourceRef="rollup_check_gw" targetRef="auto_rollup_feature">
      <bpmn:conditionExpression>all_tasks_complete == True and feature_status == "in_progress"</bpmn:conditionExpression>
    </bpmn:sequenceFlow>

    <bpmn:sequenceFlow id="flow_rollup_not_ready" sourceRef="rollup_check_gw" targetRef="next_task_gw"/>

    <bpmn:sequenceFlow id="flow_auto_rollup_to_end" sourceRef="auto_rollup_feature" targetRef="end_auto_rollup"/>

    <!-- High complexity path: spawn_agents → merge -->
    <bpmn:sequenceFlow id="flow_spawn_to_merge" sourceRef="spawn_agents" targetRef="implementation_merge"/>

    <bpmn:sequenceFlow id="flow_merge_to_run_tests" sourceRef="implementation_merge" targetRef="run_tests"/>

    <bpmn:sequenceFlow id="flow_run_tests_to_gateway" sourceRef="run_tests" targetRef="tests_pass_gateway"/>

    <bpmn:sequenceFlow id="flow_tests_pass" sourceRef="tests_pass_gateway" targetRef="review_code">
      <bpmn:conditionExpression>tests_passed == True</bpmn:conditionExpression>
    </bpmn:sequenceFlow>

    <bpmn:sequenceFlow id="flow_tests_fail" sourceRef="tests_pass_gateway" targetRef="fix_issues"/>

    <bpmn:sequenceFlow id="flow_fix_to_run_tests" sourceRef="fix_issues" targetRef="run_tests"/>

    <bpmn:sequenceFlow id="flow_review_to_result_gateway" sourceRef="review_code" targetRef="review_result_gateway"/>

    <bpmn:sequenceFlow id="flow_changes_requested" sourceRef="review_result_gateway" targetRef="fix_issues_review">
      <bpmn:conditionExpression>review == "changes_requested"</bpmn:conditionExpression>
    </bpmn:sequenceFlow>

    <bpmn:sequenceFlow id="flow_approved" sourceRef="review_result_gateway" targetRef="set_completed"/>

    <bpmn:sequenceFlow id="flow_fix_review_to_run_tests" sourceRef="fix_issues_review" targetRef="run_tests"/>
    <bpmn:sequenceFlow id="flow_set_completed_to_end" sourceRef="set_completed" targetRef="end_completed"/>

  </bpmn:process>

  <!-- Diagram layout -->
  <bpmndi:BPMNDiagram id="BPMNDiagram_1">
    <bpmndi:BPMNPlane id="BPMNPlane_1" bpmnElement="feature_workflow">

      <!-- Row 1: main setup path (y=200) -->
      <bpmndi:BPMNShape id="shape_start_event" bpmnElement="start_event">
        <dc:Bounds x="60" y="200" width="36" height="36"/>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="shape_create_feature" bpmnElement="create_feature">
        <dc:Bounds x="150" y="180" width="100" height="80"/>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="shape_set_draft" bpmnElement="set_draft">
        <dc:Bounds x="310" y="180" width="100" height="80"/>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="shape_plan_feature" bpmnElement="plan_feature">
        <dc:Bounds x="470" y="180" width="100" height="80"/>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="shape_set_planned" bpmnElement="set_planned">
        <dc:Bounds x="630" y="180" width="100" height="80"/>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="shape_create_build_tasks" bpmnElement="create_build_tasks">
        <dc:Bounds x="790" y="180" width="140" height="80"/>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="shape_set_in_progress" bpmnElement="set_in_progress">
        <dc:Bounds x="990" y="180" width="140" height="80"/>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="shape_complexity_gateway" bpmnElement="complexity_gateway" isMarkerVisible="true">
        <dc:Bounds x="1190" y="193" width="50" height="50"/>
      </bpmndi:BPMNShape>

      <!-- Row 1 upper: spawn_agents (y=80) -->
      <bpmndi:BPMNShape id="shape_spawn_agents" bpmnElement="spawn_agents">
        <dc:Bounds x="1300" y="80" width="100" height="80"/>
      </bpmndi:BPMNShape>

      <!-- Row 1 lower: implement_directly (y=330) -->
      <bpmndi:BPMNShape id="shape_implement_directly" bpmnElement="implement_directly">
        <dc:Bounds x="1300" y="330" width="120" height="80"/>
      </bpmndi:BPMNShape>

      <!-- Per-task loop (y=490) -->
      <bpmndi:BPMNShape id="shape_next_task_gw" bpmnElement="next_task_gw" isMarkerVisible="true">
        <dc:Bounds x="1450" y="503" width="50" height="50"/>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="shape_start_task" bpmnElement="start_task">
        <dc:Bounds x="1560" y="490" width="120" height="80"/>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="shape_implement_task" bpmnElement="implement_task">
        <dc:Bounds x="1740" y="490" width="120" height="80"/>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="shape_complete_task" bpmnElement="complete_task">
        <dc:Bounds x="1920" y="490" width="120" height="80"/>
      </bpmndi:BPMNShape>

      <!-- F209: auto-rollup path shapes (below per-task loop) -->
      <bpmndi:BPMNShape id="shape_rollup_check_gw" bpmnElement="rollup_check_gw" isMarkerVisible="true">
        <dc:Bounds x="1955" y="693" width="50" height="50"/>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="shape_auto_rollup_feature" bpmnElement="auto_rollup_feature">
        <dc:Bounds x="2100" y="680" width="160" height="80"/>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="shape_end_auto_rollup" bpmnElement="end_auto_rollup">
        <dc:Bounds x="2300" y="700" width="36" height="36"/>
      </bpmndi:BPMNShape>

      <!-- implementation_merge gateway -->
      <bpmndi:BPMNShape id="shape_implementation_merge" bpmnElement="implementation_merge" isMarkerVisible="true">
        <dc:Bounds x="2090" y="193" width="50" height="50"/>
      </bpmndi:BPMNShape>

      <!-- run_tests task -->
      <bpmndi:BPMNShape id="shape_run_tests" bpmnElement="run_tests">
        <dc:Bounds x="2200" y="180" width="100" height="80"/>
      </bpmndi:BPMNShape>

      <!-- tests_pass_gateway -->
      <bpmndi:BPMNShape id="shape_tests_pass_gateway" bpmnElement="tests_pass_gateway" isMarkerVisible="true">
        <dc:Bounds x="2360" y="193" width="50" height="50"/>
      </bpmndi:BPMNShape>

      <!-- fix_issues task (below, loops back to run_tests) -->
      <bpmndi:BPMNShape id="shape_fix_issues" bpmnElement="fix_issues">
        <dc:Bounds x="2360" y="340" width="100" height="80"/>
      </bpmndi:BPMNShape>

      <!-- review_code task -->
      <bpmndi:BPMNShape id="shape_review_code" bpmnElement="review_code">
        <dc:Bounds x="2470" y="180" width="100" height="80"/>
      </bpmndi:BPMNShape>

      <!-- review_result_gateway -->
      <bpmndi:BPMNShape id="shape_review_result_gateway" bpmnElement="review_result_gateway" isMarkerVisible="true">
        <dc:Bounds x="2630" y="193" width="50" height="50"/>
      </bpmndi:BPMNShape>

      <!-- fix_issues_review task (below, loops back to run_tests) -->
      <bpmndi:BPMNShape id="shape_fix_issues_review" bpmnElement="fix_issues_review">
        <dc:Bounds x="2630" y="340" width="100" height="80"/>
      </bpmndi:BPMNShape>

      <!-- set_completed task -->
      <bpmndi:BPMNShape id="shape_set_completed" bpmnElement="set_completed">
        <dc:Bounds x="2740" y="180" width="100" height="80"/>
      </bpmndi:BPMNShape>

      <!-- end_completed event -->
      <bpmndi:BPMNShape id="shape_end_completed" bpmnElement="end_completed">
        <dc:Bounds x="2900" y="200" width="36" height="36"/>
      </bpmndi:BPMNShape>

      <!-- Edges: main setup path -->
      <bpmndi:BPMNEdge id="edge_flow_start_to_create" bpmnElement="flow_start_to_create">
        <di:waypoint x="96" y="218"/>
        <di:waypoint x="150" y="220"/>
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="edge_flow_create_to_set_draft" bpmnElement="flow_create_to_set_draft">
        <di:waypoint x="250" y="220"/>
        <di:waypoint x="310" y="220"/>
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="edge_flow_set_draft_to_plan" bpmnElement="flow_set_draft_to_plan">
        <di:waypoint x="410" y="220"/>
        <di:waypoint x="470" y="220"/>
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="edge_flow_plan_to_set_planned" bpmnElement="flow_plan_to_set_planned">
        <di:waypoint x="570" y="220"/>
        <di:waypoint x="630" y="220"/>
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="edge_flow_set_planned_to_create_tasks" bpmnElement="flow_set_planned_to_create_tasks">
        <di:waypoint x="730" y="220"/>
        <di:waypoint x="790" y="220"/>
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="edge_flow_create_tasks_to_set_in_progress" bpmnElement="flow_create_tasks_to_set_in_progress">
        <di:waypoint x="930" y="220"/>
        <di:waypoint x="990" y="220"/>
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="edge_flow_set_in_progress_to_complexity" bpmnElement="flow_set_in_progress_to_complexity">
        <di:waypoint x="1130" y="220"/>
        <di:waypoint x="1190" y="218"/>
      </bpmndi:BPMNEdge>

      <!-- complexity gateway branches -->
      <bpmndi:BPMNEdge id="edge_flow_high_complexity" bpmnElement="flow_high_complexity">
        <di:waypoint x="1215" y="193"/>
        <di:waypoint x="1215" y="120"/>
        <di:waypoint x="1300" y="120"/>
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="edge_flow_simple" bpmnElement="flow_simple">
        <di:waypoint x="1215" y="243"/>
        <di:waypoint x="1215" y="370"/>
        <di:waypoint x="1300" y="370"/>
      </bpmndi:BPMNEdge>

      <!-- implement_directly → next_task_gw -->
      <bpmndi:BPMNEdge id="edge_flow_implement_to_next_task" bpmnElement="flow_implement_to_next_task">
        <di:waypoint x="1420" y="370"/>
        <di:waypoint x="1475" y="370"/>
        <di:waypoint x="1475" y="503"/>
      </bpmndi:BPMNEdge>

      <!-- Per-task loop edges -->
      <bpmndi:BPMNEdge id="edge_flow_has_next_task" bpmnElement="flow_has_next_task">
        <di:waypoint x="1500" y="528"/>
        <di:waypoint x="1560" y="530"/>
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="edge_flow_no_next_task" bpmnElement="flow_no_next_task">
        <di:waypoint x="1475" y="503"/>
        <di:waypoint x="1475" y="218"/>
        <di:waypoint x="2090" y="218"/>
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="edge_flow_start_task_to_implement" bpmnElement="flow_start_task_to_implement">
        <di:waypoint x="1680" y="530"/>
        <di:waypoint x="1740" y="530"/>
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="edge_flow_implement_task_to_complete" bpmnElement="flow_implement_task_to_complete">
        <di:waypoint x="1860" y="530"/>
        <di:waypoint x="1920" y="530"/>
      </bpmndi:BPMNEdge>

      <!-- F209: complete_task → rollup_check_gw (new gateway below complete_task) -->
      <bpmndi:BPMNEdge id="edge_flow_complete_task_to_rollup_check" bpmnElement="flow_complete_task_to_rollup_check">
        <di:waypoint x="1980" y="570"/>
        <di:waypoint x="1980" y="693"/>
      </bpmndi:BPMNEdge>

      <!-- F209: rollup_check_gw → auto_rollup_feature (when ready) -->
      <bpmndi:BPMNEdge id="edge_flow_rollup_ready" bpmnElement="flow_rollup_ready">
        <di:waypoint x="2005" y="718"/>
        <di:waypoint x="2100" y="720"/>
      </bpmndi:BPMNEdge>

      <!-- F209: rollup_check_gw → next_task_gw (not ready, continue loop) -->
      <bpmndi:BPMNEdge id="edge_flow_rollup_not_ready" bpmnElement="flow_rollup_not_ready">
        <di:waypoint x="1980" y="743"/>
        <di:waypoint x="1980" y="790"/>
        <di:waypoint x="1475" y="790"/>
        <di:waypoint x="1475" y="553"/>
      </bpmndi:BPMNEdge>

      <!-- F209: auto_rollup_feature → end_auto_rollup -->
      <bpmndi:BPMNEdge id="edge_flow_auto_rollup_to_end" bpmnElement="flow_auto_rollup_to_end">
        <di:waypoint x="2260" y="720"/>
        <di:waypoint x="2300" y="718"/>
      </bpmndi:BPMNEdge>

      <!-- spawn_agents to merge -->
      <bpmndi:BPMNEdge id="edge_flow_spawn_to_merge" bpmnElement="flow_spawn_to_merge">
        <di:waypoint x="1400" y="120"/>
        <di:waypoint x="2115" y="120"/>
        <di:waypoint x="2115" y="193"/>
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="edge_flow_merge_to_run_tests" bpmnElement="flow_merge_to_run_tests">
        <di:waypoint x="2140" y="218"/>
        <di:waypoint x="2200" y="220"/>
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="edge_flow_run_tests_to_gateway" bpmnElement="flow_run_tests_to_gateway">
        <di:waypoint x="2300" y="220"/>
        <di:waypoint x="2360" y="218"/>
      </bpmndi:BPMNEdge>

      <!-- tests_pass_gateway branches -->
      <bpmndi:BPMNEdge id="edge_flow_tests_pass" bpmnElement="flow_tests_pass">
        <di:waypoint x="2410" y="218"/>
        <di:waypoint x="2470" y="220"/>
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="edge_flow_tests_fail" bpmnElement="flow_tests_fail">
        <di:waypoint x="2385" y="243"/>
        <di:waypoint x="2385" y="380"/>
        <di:waypoint x="2360" y="380"/>
      </bpmndi:BPMNEdge>

      <!-- fix_issues loop back to run_tests -->
      <bpmndi:BPMNEdge id="edge_flow_fix_to_run_tests" bpmnElement="flow_fix_to_run_tests">
        <di:waypoint x="2360" y="380"/>
        <di:waypoint x="2250" y="380"/>
        <di:waypoint x="2250" y="260"/>
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="edge_flow_review_to_result_gateway" bpmnElement="flow_review_to_result_gateway">
        <di:waypoint x="2570" y="220"/>
        <di:waypoint x="2630" y="218"/>
      </bpmndi:BPMNEdge>

      <!-- review_result_gateway branches -->
      <bpmndi:BPMNEdge id="edge_flow_changes_requested" bpmnElement="flow_changes_requested">
        <di:waypoint x="2655" y="243"/>
        <di:waypoint x="2655" y="380"/>
        <di:waypoint x="2630" y="380"/>
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="edge_flow_approved" bpmnElement="flow_approved">
        <di:waypoint x="2680" y="218"/>
        <di:waypoint x="2740" y="220"/>
      </bpmndi:BPMNEdge>

      <!-- fix_issues_review loop back to run_tests -->
      <bpmndi:BPMNEdge id="edge_flow_fix_review_to_run_tests" bpmnElement="flow_fix_review_to_run_tests">
        <di:waypoint x="2630" y="380"/>
        <di:waypoint x="2250" y="480"/>
        <di:waypoint x="2250" y="260"/>
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="edge_flow_set_completed_to_end" bpmnElement="flow_set_completed_to_end">
        <di:waypoint x="2840" y="220"/>
        <di:waypoint x="2900" y="218"/>
      </bpmndi:BPMNEdge>

    </bpmndi:BPMNPlane>
  </bpmndi:BPMNDiagram>

</bpmn:definitions>
