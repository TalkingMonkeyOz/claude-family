#!/bin/bash
# Code Knowledge Graph — post-commit hook
# Spawns async re-index after each commit to keep the CKG fresh.
# Install: ln -s /c/Projects/claude-family/scripts/git-hooks/post-commit .git/hooks/post-commit
#
# Non-blocking: the indexer runs in the background, commit returns immediately.
# Incremental: only re-parses files that changed (SHA-256 hash comparison).

SCRIPTS_DIR="$(cd "$(dirname "$(readlink -f "$0" 2>/dev/null || echo "$0")")/../.." 2>/dev/null && pwd)/scripts"
# Fallback to the known location
if [ ! -f "$SCRIPTS_DIR/code_indexer.py" ]; then
    SCRIPTS_DIR="C:/Projects/claude-family/scripts"
fi

PROJECT_NAME=$(basename "$(git rev-parse --show-toplevel)")
PROJECT_PATH=$(git rev-parse --show-toplevel)

if [ -f "$SCRIPTS_DIR/code_indexer.py" ]; then
    python "$SCRIPTS_DIR/code_indexer.py" "$PROJECT_NAME" "$PROJECT_PATH" &
fi
